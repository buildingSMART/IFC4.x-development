        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcGeometricRepresentationContext_Precision_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcGeometricRepresentationContext_Precision_upper" value="1"/>
      </ownedAttribute>
