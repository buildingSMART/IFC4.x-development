    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcShapeAspect" name="IfcShapeAspect">
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcShapeAspect_ShapeRepresentations" name="ShapeRepresentations_L[1:?]" type="cl_IfcShapeModel" association="as_IfcShapeAspect_ShapeRepresentations">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcShapeAspect_ShapeRepresentations_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcShapeAspect_ShapeRepresentations_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcShapeAspect_Name" name="Name">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcShapeAspect_Name_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcShapeAspect_Name_upper" value="1"/>
