)) = 0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcTopologyRepresentation_WR22" name="WR22">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcTopologyRepresentation_WR22" name="WR22">
          <language>EXPRESS_WHERE</language>
          <body>EXISTS(SELF\IfcRepresentation.RepresentationType)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcTopologyRepresentation_WR23" name="WR23">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcTopologyRepresentation_WR23" name="WR23">
          <language>EXPRESS_WHERE</language>
          <body>IfcTopologyRepresentationTypes(SELF\IfcRepresentation.RepresentationType, SELF\IfcRepresentation.Items)</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcTopologyRepresentation_gen_IfcShapeModel" general="cl_IfcShapeModel"/>
    </packagedElement>
