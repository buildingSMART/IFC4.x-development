        <type xmi:type="uml:Class" href="IfcGeometryResource.uml#un_IfcAxis2Placement"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcGeometricRepresentationContext_WorldCoordinateSystem_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcGeometricRepresentationContext_WorldCoordinateSystem_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcGeometricRepresentationContext_TrueNorth" name="TrueNorth" association="as_IfcGeometricRepresentationContext_TrueNorth">
        <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcDirection"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcGeometricRepresentationContext_TrueNorth_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcGeometricRepresentationContext_TrueNorth_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcMapConversion" name="IfcMapConversion">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcMapConversion_TargetCRSOnlyProjected" name="TargetCRSOnlyProjected">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcMapConversion_TargetCRSOnlyProjected" name="TargetCRSOnlyProjected">
          <language>EXPRESS_WHERE</language>
          <body>'IFC4X3_ADD2.IFCPROJECTEDCRS' IN TYPEOF(SELF\IfcCoordinateOperation.TargetCRS)</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcMapConversion_gen_IfcCoordinateOperation" general="cl_IfcCoordinateOperation"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcMapConversion_Eastings" name="Eastings">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcMapConversion_Eastings_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcMapConversion_Eastings_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcMapConversion_Northings" name="Northings">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcMapConversion_Northings_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcMapConversion_Northings_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcMapConversion_OrthogonalHeight" name="OrthogonalHeight">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcMapConversion_OrthogonalHeight_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcMapConversion_OrthogonalHeight_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcMapConversion_XAxisAbscissa" name="XAxisAbscissa">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcReal"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcMapConversion_XAxisAbscissa_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcMapConversion_XAxisAbscissa_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcMapConversion_XAxisOrdinate" name="XAxisOrdinate">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcReal"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcMapConversion_XAxisOrdinate_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcMapConversion_XAxisOrdinate_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcMapConversion_Scale" name="Scale">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcReal"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcMapConversion_Scale_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcMapConversion_Scale_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcMaterialDefinitionRepresentation" name="IfcMaterialDefinitionRepresentation">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcMaterialDefinitionRepresentation_OnlyStyledRepresentations" name="OnlyStyledRepresentations">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcMaterialDefinitionRepresentation_OnlyStyledRepresentations" name="OnlyStyledRepresentations">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(temp &lt;* Representations | 
  (NOT('IFC4X3_ADD2.IFCSTYLEDREPRESENTATION' IN TYPEOF(temp)))
)) = 0</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcMaterialDefinitionRepresentation_gen_IfcProductRepresentation" general="cl_IfcProductRepresentation"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcMaterialDefinitionRepresentation_RepresentedMaterial" name="RepresentedMaterial" association="as_IfcMaterialDefinitionRepresentation_RepresentedMaterial">
        <type xmi:type="uml:Class" href="IfcMaterialResource.uml#cl_IfcMaterial"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcMaterialDefinitionRepresentation_RepresentedMaterial_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcMaterialDefinitionRepresentation_RepresentedMaterial_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcProductDefinitionShape" name="IfcProductDefinitionShape">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcProductDefinitionShape_OnlyShapeModel" name="OnlyShapeModel">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcProductDefinitionShape_OnlyShapeModel" name="OnlyShapeModel">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(temp &lt;* Representations | 
  (NOT('IFC4X3_ADD2.IFCSHAPEMODEL' IN TYPEOF(temp)))
)) = 0</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcProductDefinitionShape_gen_IfcProductRepresentation" general="cl_IfcProductRepresentation"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcProjectedCRS" name="IfcProjectedCRS">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcProjectedCRS_MapUnitIsLength" name="MapUnitIsLength">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcProjectedCRS_MapUnitIsLength" name="MapUnitIsLength">
          <language>EXPRESS_WHERE</language>
          <body>NOT(EXISTS(SELF.MapUnit)) OR (SELF.MapUnit.UnitType = IfcUnitEnum.LENGTHUNIT)</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcProjectedCRS_gen_IfcCoordinateReferenceSystem" general="cl_IfcCoordinateReferenceSystem"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcProjectedCRS_VerticalDatum" name="VerticalDatum">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcIdentifier"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcProjectedCRS_VerticalDatum_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcProjectedCRS_VerticalDatum_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcProjectedCRS_MapProjection" name="MapProjection">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcIdentifier"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcProjectedCRS_MapProjection_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcProjectedCRS_MapProjection_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcProjectedCRS_MapZone" name="MapZone">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcIdentifier"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcProjectedCRS_MapZone_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcProjectedCRS_MapZone_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcProjectedCRS_MapUnit" name="MapUnit" association="as_IfcProjectedCRS_MapUnit">
        <type xmi:type="uml:Class" href="IfcMeasureResource.uml#cl_IfcNamedUnit"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcProjectedCRS_MapUnit_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcProjectedCRS_MapUnit_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcRigidOperation" name="IfcRigidOperation">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRigidOperation_SameCoordinateType" name="SameCoordinateType">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcRigidOperation_SameCoordinateType" name="SameCoordinateType">
          <language>EXPRESS_WHERE</language>
          <body>(('IFC4X3_ADD2.IFCLENGTHMEASURE' IN TYPEOF(FirstCoordinate)) AND ('IFC4X3_ADD2.IFCLENGTHMEASURE' IN TYPEOF(SecondCoordinate))) OR (('IFC4X3_ADD2.IFCPLANEANGLEMEASURE' IN TYPEOF(FirstCoordinate)) AND ('IFC4X3_ADD2.IFCPLANEANGLEMEASURE' IN TYPEOF(SecondCoordinate)))</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcRigidOperation_gen_IfcCoordinateOperation" general="cl_IfcCoordinateOperation"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRigidOperation_FirstCoordinate" name="FirstCoordinate" association="as_IfcRigidOperation_FirstCoordinate">
        <type xmi:type="uml:Class" href="IfcMeasureResource.uml#un_IfcMeasureValue"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcRigidOperation_FirstCoordinate_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcRigidOperation_FirstCoordinate_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRigidOperation_SecondCoordinate" name="SecondCoordinate" association="as_IfcRigidOperation_SecondCoordinate">
        <type xmi:type="uml:Class" href="IfcMeasureResource.uml#un_IfcMeasureValue"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcRigidOperation_SecondCoordinate_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcRigidOperation_SecondCoordinate_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRigidOperation_Height" name="Height">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcRigidOperation_Height_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcRigidOperation_Height_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcShapeModel" name="IfcShapeModel" isAbstract="true">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcShapeModel_WR11" name="WR11">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcShapeModel_WR11" name="WR11">
          <language>EXPRESS_WHERE</language>
          <body>(SIZEOF(SELF\IfcRepresentation.OfProductRepresentation) = 1) XOR 
(SIZEOF(SELF\IfcRepresentation.RepresentationMap) = 1) XOR
(SIZEOF(OfShapeAspect) = 1)</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcShapeModel_gen_IfcRepresentation" general="cl_IfcRepresentation"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcStyleModel" name="IfcStyleModel" isAbstract="true">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcStyleModel_gen_IfcRepresentation" general="cl_IfcRepresentation"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="un_IfcCoordinateReferenceSystemSelect" name="IfcCoordinateReferenceSystemSelect"/>
    <packagedElement xmi:type="uml:Dependency" xmi:id="dp_IfcCoordinateReferenceSystemSelect_IfcCoordinateReferenceSystem" client="un_IfcCoordinateReferenceSystemSelect" supplier="cl_IfcCoordinateReferenceSystem"/>
    <packagedElement xmi:type="uml:Dependency" xmi:id="dp_IfcCoordinateReferenceSystemSelect_IfcGeometricRepresentationContext" client="un_IfcCoordinateReferenceSystemSelect" supplier="cl_IfcGeometricRepresentationContext"/>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcGeometricRepresentationSubContext" name="IfcGeometricRepresentationSubContext">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcGeometricRepresentationSubContext_NoCoordOperation" name="NoCoordOperation">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcGeometricRepresentationSubContext_NoCoordOperation" name="NoCoordOperation">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(SELF\IfcGeometricRepresentationContext.HasCoordinateOperation) = 0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcGeometricRepresentationSubContext_ParentNoSub" name="ParentNoSub">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcGeometricRepresentationSubContext_ParentNoSub" name="ParentNoSub">
          <language>EXPRESS_WHERE</language>
          <body>NOT('IFC4X3_ADD2.IFCGEOMETRICREPRESENTATIONSUBCONTEXT' IN TYPEOF(ParentContext))</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcGeometricRepresentationSubContext_UserTargetProvided" name="UserTargetProvided">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcGeometricRepresentationSubContext_UserTargetProvided" name="UserTargetProvided">
          <language>EXPRESS_WHERE</language>
          <body>(TargetView &lt;&gt; IfcGeometricProjectionEnum.USERDEFINED) OR 
((TargetView =  IfcGeometricProjectionEnum.USERDEFINED) AND EXISTS(UserDefinedTargetView))</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcGeometricRepresentationSubContext_gen_IfcGeometricRepresentationContext" general="cl_IfcGeometricRepresentationContext"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcGeometricRepresentationSubContext_ParentContext" name="ParentContext" type="cl_IfcGeometricRepresentationContext" association="as_IfcGeometricRepresentationSubContext_ParentContext">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcGeometricRepresentationSubContext_ParentContext_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcGeometricRepresentationSubContext_ParentContext_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcGeometricRepresentationSubContext_TargetScale" name="TargetScale">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveRatioMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcGeometricRepresentationSubContext_TargetScale_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcGeometricRepresentationSubContext_TargetScale_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcGeometricRepresentationSubContext_TargetView" name="TargetView" type="en_IfcGeometricProjectionEnum">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcGeometricRepresentationSubContext_TargetView_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcGeometricRepresentationSubContext_TargetView_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcGeometricRepresentationSubContext_UserDefinedTargetView" name="UserDefinedTargetView">
