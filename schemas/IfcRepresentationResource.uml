        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCoordinateOperation_TargetCRS_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcCoordinateReferenceSystem" name="IfcCoordinateReferenceSystem" isAbstract="true">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCoordinateReferenceSystem_NameOrWKT" name="NameOrWKT">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcCoordinateReferenceSystem_NameOrWKT" name="NameOrWKT">
          <language>EXPRESS_WHERE</language>
          <body>(HIINDEX(WellKnownText) = 1) OR EXISTS(Name)</body>
        </specification>
      </ownedRule>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCoordinateReferenceSystem_Name" name="Name">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
