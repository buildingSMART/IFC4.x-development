      <generalization xmi:type="uml:Generalization" xmi:id="dt_IfcWellKnownTextLiteral_gen_string">
        <general xmi:type="uml:DataType" href="ifc4x3_add2.uml#dt_string"/>
      </generalization>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcGeographicCRS" name="IfcGeographicCRS">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcGeographicCRS_AngleUnitIsPlaneAngle" name="AngleUnitIsPlaneAngle">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcGeographicCRS_AngleUnitIsPlaneAngle" name="AngleUnitIsPlaneAngle">
          <language>EXPRESS_WHERE</language>
          <body>NOT(EXISTS(SELF.AngleUnit)) OR (SELF.AngleUnit.UnitType=IfcUnitEnum.PLANEANGLEUNIT)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcGeographicCRS_HeightUnitIsLength" name="HeightUnitIsLength">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcGeographicCRS_HeightUnitIsLength" name="HeightUnitIsLength">
          <language>EXPRESS_WHERE</language>
          <body>NOT(EXISTS(SELF.HeightUnit)) OR (SELF.HeightUnit.UnitType=IfcUnitEnum.LENGTHUNIT)</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcGeographicCRS_gen_IfcCoordinateReferenceSystem" general="cl_IfcCoordinateReferenceSystem"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcGeographicCRS_PrimeMeridian" name="PrimeMeridian">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcIdentifier"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcGeographicCRS_PrimeMeridian_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcGeographicCRS_PrimeMeridian_upper" value="1"/>
      </ownedAttribute>
