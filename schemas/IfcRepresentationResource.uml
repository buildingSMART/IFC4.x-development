        <type xmi:type="uml:Class" href="IfcMeasureResource.uml#cl_IfcNamedUnit"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcGeographicCRS_AngleUnit_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcGeographicCRS_AngleUnit_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcGeographicCRS_HeightUnit" name="HeightUnit" association="as_IfcGeographicCRS_HeightUnit">
        <type xmi:type="uml:Class" href="IfcMeasureResource.uml#cl_IfcNamedUnit"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcGeographicCRS_HeightUnit_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcGeographicCRS_HeightUnit_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcGeometricRepresentationContext" name="IfcGeometricRepresentationContext">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcGeometricRepresentationContext_North2D" name="North2D">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcGeometricRepresentationContext_North2D" name="North2D">
          <language>EXPRESS_WHERE</language>
          <body>NOT(EXISTS(TrueNorth)) OR (HIINDEX(TrueNorth.DirectionRatios) = 2)</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcGeometricRepresentationContext_gen_IfcRepresentationContext" general="cl_IfcRepresentationContext"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcGeometricRepresentationContext_CoordinateSpaceDimension" name="CoordinateSpaceDimension">
        <type xmi:type="uml:DataType" href="IfcGeometryResource.uml#dt_IfcDimensionCount"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcGeometricRepresentationContext_CoordinateSpaceDimension_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcGeometricRepresentationContext_CoordinateSpaceDimension_upper" value="1"/>
