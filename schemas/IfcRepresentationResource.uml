        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCoordinateReferenceSystem_Name_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCoordinateReferenceSystem_Description" name="Description">
