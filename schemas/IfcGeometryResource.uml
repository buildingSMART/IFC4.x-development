      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOffsetCurveByDistances_OffsetValues" name="OffsetValues_L[1:?]" type="cl_IfcPointByDistanceExpression" association="as_IfcOffsetCurveByDistances_OffsetValues">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcOffsetCurveByDistances_OffsetValues_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcOffsetCurveByDistances_OffsetValues_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOffsetCurveByDistances_Tag" name="Tag">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcOffsetCurveByDistances_Tag_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcOffsetCurveByDistances_Tag_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcPlane" name="IfcPlane">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcPlane_gen_IfcElementarySurface" general="cl_IfcElementarySurface"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcPolyline" name="IfcPolyline">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPolyline_SameDim" name="SameDim">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcPolyline_SameDim" name="SameDim">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(Temp &lt;* Points | Temp.Dim &lt;&gt; Points[1].Dim)) = 0</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcPolyline_gen_IfcBoundedCurve" general="cl_IfcBoundedCurve"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPolyline_Points" name="Points_L[2:?]" type="cl_IfcCartesianPoint" association="as_IfcPolyline_Points">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcPolyline_Points_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPolyline_Points_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcRectangularTrimmedSurface" name="IfcRectangularTrimmedSurface">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRectangularTrimmedSurface_U1AndU2Different" name="U1AndU2Different">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcRectangularTrimmedSurface_U1AndU2Different" name="U1AndU2Different">
          <language>EXPRESS_WHERE</language>
          <body>U1 &lt;&gt; U2</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRectangularTrimmedSurface_UsenseCompatible" name="UsenseCompatible">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcRectangularTrimmedSurface_UsenseCompatible" name="UsenseCompatible">
          <language>EXPRESS_WHERE</language>
          <body>(('IFC4X3_ADD2.IFCELEMENTARYSURFACE' IN TYPEOF(BasisSurface)) AND
         (NOT ('IFC4X3_ADD2.IFCPLANE' IN TYPEOF(BasisSurface)))) OR
         ('IFC4X3_ADD2.IFCSURFACEOFREVOLUTION' IN TYPEOF(BasisSurface)) OR
         (Usense = (U2 &gt; U1))</body>
        </specification>
      </ownedRule>
