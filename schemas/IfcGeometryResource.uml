    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcClothoid" name="IfcClothoid">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcClothoid_gen_IfcSpiral" general="cl_IfcSpiral"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcClothoid_ClothoidConstant" name="ClothoidConstant">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcClothoid_ClothoidConstant_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcClothoid_ClothoidConstant_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcCompositeCurve" name="IfcCompositeCurve">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCompositeCurve_CurveContinuous" name="CurveContinuous">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcCompositeCurve_CurveContinuous" name="CurveContinuous">
          <language>EXPRESS_WHERE</language>
          <body>((NOT ClosedCurve) AND (SIZEOF(QUERY(Temp &lt;* Segments | Temp.Transition = Discontinuous)) = 1)) OR ((ClosedCurve) AND (SIZEOF(QUERY(Temp &lt;* Segments | Temp.Transition = Discontinuous)) = 0))</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCompositeCurve_SameDim" name="SameDim">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcCompositeCurve_SameDim" name="SameDim">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF( QUERY( Temp &lt;* Segments | Temp.Dim &lt;&gt; Segments[1].Dim)) = 0</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcCompositeCurve_gen_IfcBoundedCurve" general="cl_IfcBoundedCurve"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCompositeCurve_Segments" name="Segments_L[1:?]" type="cl_IfcSegment" association="as_IfcCompositeCurve_Segments">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCompositeCurve_Segments_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCompositeCurve_Segments_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCompositeCurve_SelfIntersect" name="SelfIntersect">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLogical"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCompositeCurve_SelfIntersect_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCompositeCurve_SelfIntersect_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCompositeCurve_NSegments" name="NSegments" isDerived="true">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcInteger"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCompositeCurve_NSegments_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCompositeCurve_NSegments_upper" value="1"/>
        <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="at_IfcCompositeCurve_NSegments_expr" name="NSegments">
          <language>EXPRESS</language>
          <body>IfcInteger := SIZEOF(Segments)</body>
        </defaultValue>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCompositeCurve_ClosedCurve" name="ClosedCurve" isDerived="true">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLogical"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCompositeCurve_ClosedCurve_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCompositeCurve_ClosedCurve_upper" value="1"/>
        <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="at_IfcCompositeCurve_ClosedCurve_expr" name="ClosedCurve">
          <language>EXPRESS</language>
          <body>IfcLogical := Segments[NSegments].Transition &lt;&gt; Discontinuous</body>
        </defaultValue>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcCosineSpiral" name="IfcCosineSpiral">
