        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcEllipse_SemiAxis2_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcEllipse_SemiAxis2_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcIndexedPolyCurve" name="IfcIndexedPolyCurve">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcIndexedPolyCurve_Consecutive" name="Consecutive">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcIndexedPolyCurve_Consecutive" name="Consecutive">
          <language>EXPRESS_WHERE</language>
          <body>NOT(EXISTS(Segments)) OR IfcConsecutiveSegments(Segments)</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcIndexedPolyCurve_gen_IfcBoundedCurve" general="cl_IfcBoundedCurve"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcIndexedPolyCurve_Points" name="Points" association="as_IfcIndexedPolyCurve_Points">
        <type xmi:type="uml:Class" href="IfcGeometricModelResource.uml#cl_IfcCartesianPointList"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcIndexedPolyCurve_Points_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcIndexedPolyCurve_Points_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcIndexedPolyCurve_Segments" name="Segments_L[1:?]" type="un_IfcSegmentIndexSelect" association="as_IfcIndexedPolyCurve_Segments">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcIndexedPolyCurve_Segments_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcIndexedPolyCurve_Segments_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcIndexedPolyCurve_SelfIntersect" name="SelfIntersect">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcBoolean"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcIndexedPolyCurve_SelfIntersect_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcIndexedPolyCurve_SelfIntersect_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcIntersectionCurve" name="IfcIntersectionCurve">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcIntersectionCurve_DistinctSurfaces" name="DistinctSurfaces">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcIntersectionCurve_DistinctSurfaces" name="DistinctSurfaces">
          <language>EXPRESS_WHERE</language>
          <body>IfcAssociatedSurface(SELF\IfcSurfaceCurve.AssociatedGeometry[1]) &lt;&gt; IfcAssociatedSurface(SELF\IfcSurfaceCurve.AssociatedGeometry[2])</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcIntersectionCurve_TwoPCurves" name="TwoPCurves">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcIntersectionCurve_TwoPCurves" name="TwoPCurves">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(SELF\IfcSurfaceCurve.AssociatedGeometry) = 2</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcIntersectionCurve_gen_IfcSurfaceCurve" general="cl_IfcSurfaceCurve"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcOffsetCurve2D" name="IfcOffsetCurve2D">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcOffsetCurve2D_DimIs2D" name="DimIs2D">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcOffsetCurve2D_DimIs2D" name="DimIs2D">
          <language>EXPRESS_WHERE</language>
          <body>BasisCurve.Dim = 2</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcOffsetCurve2D_gen_IfcOffsetCurve" general="cl_IfcOffsetCurve"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOffsetCurve2D_Distance" name="Distance">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcOffsetCurve2D_Distance_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcOffsetCurve2D_Distance_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOffsetCurve2D_SelfIntersect" name="SelfIntersect">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLogical"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcOffsetCurve2D_SelfIntersect_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcOffsetCurve2D_SelfIntersect_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
