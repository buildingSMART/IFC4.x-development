          <body>IfcReal := NVL(Scale2, SELF\IfcCartesianTransformationOperator.Scl)</body>
        </defaultValue>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCartesianTransformationOperator3DnonUniform_Scl3" name="Scl3" isDerived="true">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcReal"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCartesianTransformationOperator3DnonUniform_Scl3_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCartesianTransformationOperator3DnonUniform_Scl3_upper" value="1"/>
        <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="at_IfcCartesianTransformationOperator3DnonUniform_Scl3_expr" name="Scl3">
          <language>EXPRESS</language>
          <body>IfcReal := NVL(Scale3, SELF\IfcCartesianTransformationOperator.Scl)</body>
        </defaultValue>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcCircle" name="IfcCircle">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcCircle_gen_IfcConic" general="cl_IfcConic"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCircle_Radius" name="Radius">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
