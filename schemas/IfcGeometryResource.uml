        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcOffsetCurve3D_SelfIntersect_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcOffsetCurve3D_SelfIntersect_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOffsetCurve3D_RefDirection" name="RefDirection" type="cl_IfcDirection" association="as_IfcOffsetCurve3D_RefDirection">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcOffsetCurve3D_RefDirection_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcOffsetCurve3D_RefDirection_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
