(SELF\IfcCartesianTransformationOperator.Axis1.Dim = 3)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCartesianTransformationOperator3D_Axis2Is3D" name="Axis2Is3D">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcCartesianTransformationOperator3D_Axis2Is3D" name="Axis2Is3D">
          <language>EXPRESS_WHERE</language>
          <body>NOT(EXISTS(SELF\IfcCartesianTransformationOperator.Axis2)) OR 
