          <body>NOT('IFC4X3_ADD2.IFCBOUNDEDCURVE' IN TYPEOF(BasisCurve))</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcTrimmedCurve_Trim1ValuesConsistent" name="Trim1ValuesConsistent">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcTrimmedCurve_Trim1ValuesConsistent" name="Trim1ValuesConsistent">
          <language>EXPRESS_WHERE</language>
          <body>(HIINDEX(Trim1) = 1) OR (TYPEOF(Trim1[1]) &lt;&gt; TYPEOF(Trim1[2]))</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcTrimmedCurve_Trim2ValuesConsistent" name="Trim2ValuesConsistent">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcTrimmedCurve_Trim2ValuesConsistent" name="Trim2ValuesConsistent">
          <language>EXPRESS_WHERE</language>
          <body>(HIINDEX(Trim2) = 1) OR (TYPEOF(Trim2[1]) &lt;&gt; TYPEOF(Trim2[2]))</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcTrimmedCurve_gen_IfcBoundedCurve" general="cl_IfcBoundedCurve"/>
