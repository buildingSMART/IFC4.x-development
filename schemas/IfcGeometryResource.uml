        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcCartesianPoint_CP2Dor3D" name="CP2Dor3D">
          <language>EXPRESS_WHERE</language>
          <body>HIINDEX(Coordinates) &gt;= 2</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcCartesianPoint_gen_IfcPoint" general="cl_IfcPoint"/>
