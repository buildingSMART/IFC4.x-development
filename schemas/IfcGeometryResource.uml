    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcRationalBSplineCurveWithKnots" name="IfcRationalBSplineCurveWithKnots">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRationalBSplineCurveWithKnots_SameNumOfWeightsAndPoints" name="SameNumOfWeightsAndPoints">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcRationalBSplineCurveWithKnots_SameNumOfWeightsAndPoints" name="SameNumOfWeightsAndPoints">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(WeightsData) = SIZEOF(SELF\IfcBSplineCurve.ControlPointsList)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRationalBSplineCurveWithKnots_WeightsGreaterZero" name="WeightsGreaterZero">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcRationalBSplineCurveWithKnots_WeightsGreaterZero" name="WeightsGreaterZero">
          <language>EXPRESS_WHERE</language>
          <body>IfcCurveWeightsPositive(SELF)</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcRationalBSplineCurveWithKnots_gen_IfcBSplineCurveWithKnots" general="cl_IfcBSplineCurveWithKnots"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRationalBSplineCurveWithKnots_WeightsData" name="WeightsData_L[2:?]">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcReal"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcRationalBSplineCurveWithKnots_WeightsData_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcRationalBSplineCurveWithKnots_WeightsData_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRationalBSplineCurveWithKnots_Weights" name="Weights" isDerived="true">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcReal"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcRationalBSplineCurveWithKnots_Weights_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcRationalBSplineCurveWithKnots_Weights_upper" value="1"/>
        <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="at_IfcRationalBSplineCurveWithKnots_Weights_expr" name="Weights">
          <language>EXPRESS</language>
          <body>ARRAY [0:UpperIndexOnControlPoints] OF IfcReal := IfcListToArray(WeightsData,0,SELF\IfcBSplineCurve.UpperIndexOnControlPoints)</body>
        </defaultValue>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcRationalBSplineSurfaceWithKnots" name="IfcRationalBSplineSurfaceWithKnots">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRationalBSplineSurfaceWithKnots_CorrespondingWeightsDataLists" name="CorrespondingWeightsDataLists">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcRationalBSplineSurfaceWithKnots_CorrespondingWeightsDataLists" name="CorrespondingWeightsDataLists">
          <language>EXPRESS_WHERE</language>
          <body>(SIZEOF(WeightsData) = SIZEOF(SELF\IfcBSplineSurface.ControlPointsList))
AND 
(SIZEOF(WeightsData[1]) = SIZEOF(SELF\IfcBSplineSurface.ControlPointsList[1]))</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRationalBSplineSurfaceWithKnots_WeightValuesGreaterZero" name="WeightValuesGreaterZero">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcRationalBSplineSurfaceWithKnots_WeightValuesGreaterZero" name="WeightValuesGreaterZero">
          <language>EXPRESS_WHERE</language>
          <body>IfcSurfaceWeightsPositive(SELF)</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcRationalBSplineSurfaceWithKnots_gen_IfcBSplineSurfaceWithKnots" general="cl_IfcBSplineSurfaceWithKnots"/>
