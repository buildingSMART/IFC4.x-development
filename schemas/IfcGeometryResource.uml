    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcCartesianTransformationOperator2D" name="IfcCartesianTransformationOperator2D">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCartesianTransformationOperator2D_Axis1Is2D" name="Axis1Is2D">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcCartesianTransformationOperator2D_Axis1Is2D" name="Axis1Is2D">
          <language>EXPRESS_WHERE</language>
          <body>NOT(EXISTS(SELF\IfcCartesianTransformationOperator.Axis1)) OR 
(SELF\IfcCartesianTransformationOperator.Axis1.Dim = 2)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCartesianTransformationOperator2D_Axis2Is2D" name="Axis2Is2D">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcCartesianTransformationOperator2D_Axis2Is2D" name="Axis2Is2D">
          <language>EXPRESS_WHERE</language>
          <body>NOT(EXISTS(SELF\IfcCartesianTransformationOperator.Axis2)) OR 
(SELF\IfcCartesianTransformationOperator.Axis2.Dim = 2)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCartesianTransformationOperator2D_DimEqual2" name="DimEqual2">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcCartesianTransformationOperator2D_DimEqual2" name="DimEqual2">
          <language>EXPRESS_WHERE</language>
          <body>SELF\IfcCartesianTransformationOperator.Dim = 2</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcCartesianTransformationOperator2D_gen_IfcCartesianTransformationOperator" general="cl_IfcCartesianTransformationOperator"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCartesianTransformationOperator2D_U" name="U" isDerived="true" type="cl_IfcDirection">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCartesianTransformationOperator2D_U_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCartesianTransformationOperator2D_U_upper" value="1"/>
        <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="at_IfcCartesianTransformationOperator2D_U_expr" name="U">
          <language>EXPRESS</language>
          <body>LIST [2:2] OF IfcDirection := IfcBaseAxis(2,SELF\IfcCartesianTransformationOperator.Axis1,
SELF\IfcCartesianTransformationOperator.Axis2,?)</body>
        </defaultValue>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcCartesianTransformationOperator3D" name="IfcCartesianTransformationOperator3D">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCartesianTransformationOperator3D_Axis1Is3D" name="Axis1Is3D">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcCartesianTransformationOperator3D_Axis1Is3D" name="Axis1Is3D">
          <language>EXPRESS_WHERE</language>
