        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCartesianPoint_Coordinates_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCartesianPoint_Coordinates_upper" value="1"/>
