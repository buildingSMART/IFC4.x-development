      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcCurveBoundedSurface" name="IfcCurveBoundedSurface">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcCurveBoundedSurface_gen_IfcBoundedSurface" general="cl_IfcBoundedSurface"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCurveBoundedSurface_BasisSurface" name="BasisSurface" type="cl_IfcSurface" association="as_IfcCurveBoundedSurface_BasisSurface">
