        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcOffsetCurve3D_DimIs2D" name="DimIs2D">
          <language>EXPRESS_WHERE</language>
          <body>BasisCurve.Dim = 3</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcOffsetCurve3D_gen_IfcOffsetCurve" general="cl_IfcOffsetCurve"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOffsetCurve3D_Distance" name="Distance">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcOffsetCurve3D_Distance_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcOffsetCurve3D_Distance_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOffsetCurve3D_SelfIntersect" name="SelfIntersect">
