      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCartesianTransformationOperator3D_U" name="U" isDerived="true" type="cl_IfcDirection">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCartesianTransformationOperator3D_U_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCartesianTransformationOperator3D_U_upper" value="1"/>
        <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="at_IfcCartesianTransformationOperator3D_U_expr" name="U">
