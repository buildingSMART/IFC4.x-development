    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcGeometricSet" name="IfcGeometricSet">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcGeometricSet_ConsistentDim" name="ConsistentDim">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcGeometricSet_ConsistentDim" name="ConsistentDim">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(Temp &lt;* Elements |
  Temp.Dim &lt;&gt; Elements[1].Dim))
= 0</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcGeometricSet_gen_IfcGeometricRepresentationItem">
        <general xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcGeometricRepresentationItem"/>
      </generalization>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcGeometricSet_Elements" name="Elements_S[1:?]" type="un_IfcGeometricSetSelect" association="as_IfcGeometricSet_Elements">
