      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcCartesianPointList3D_gen_IfcCartesianPointList" general="cl_IfcCartesianPointList"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCartesianPointList3D_CoordList" name="CoordList_L[1:?]_L[3:3]">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCartesianPointList3D_CoordList_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCartesianPointList3D_CoordList_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCartesianPointList3D_TagList" name="TagList_L[1:?]">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCartesianPointList3D_TagList_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCartesianPointList3D_TagList_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="un_IfcCsgSelect" name="IfcCsgSelect"/>
    <packagedElement xmi:type="uml:Dependency" xmi:id="dp_IfcCsgSelect_IfcBooleanResult" client="un_IfcCsgSelect" supplier="cl_IfcBooleanResult"/>
    <packagedElement xmi:type="uml:Dependency" xmi:id="dp_IfcCsgSelect_IfcCsgPrimitive3D" client="un_IfcCsgSelect" supplier="cl_IfcCsgPrimitive3D"/>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcCsgSolid" name="IfcCsgSolid">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcCsgSolid_gen_IfcSolidModel" general="cl_IfcSolidModel"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCsgSolid_TreeRootExpression" name="TreeRootExpression" type="un_IfcCsgSelect" association="as_IfcCsgSolid_TreeRootExpression">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCsgSolid_TreeRootExpression_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCsgSolid_TreeRootExpression_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcGeometricCurveSet" name="IfcGeometricCurveSet">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcGeometricCurveSet_NoSurfaces" name="NoSurfaces">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcGeometricCurveSet_NoSurfaces" name="NoSurfaces">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(Temp &lt;* SELF\IfcGeometricSet.Elements |
'IFC4X3_ADD2.IFCSURFACE' IN TYPEOF(Temp))) = 0</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcGeometricCurveSet_gen_IfcGeometricSet" general="cl_IfcGeometricSet"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="un_IfcGeometricSetSelect" name="IfcGeometricSetSelect"/>
    <packagedElement xmi:type="uml:Dependency" xmi:id="dp_IfcGeometricSetSelect_IfcCurve" client="un_IfcGeometricSetSelect">
      <supplier xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcCurve"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Dependency" xmi:id="dp_IfcGeometricSetSelect_IfcPoint" client="un_IfcGeometricSetSelect">
      <supplier xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcPoint"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Dependency" xmi:id="dp_IfcGeometricSetSelect_IfcSurface" client="un_IfcGeometricSetSelect">
      <supplier xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcSurface"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcIndexedPolygonalFace" name="IfcIndexedPolygonalFace">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcIndexedPolygonalFace_gen_IfcTessellatedItem" general="cl_IfcTessellatedItem"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcIndexedPolygonalFace_CoordIndex" name="CoordIndex_L[3:?]">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveInteger"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcIndexedPolygonalFace_CoordIndex_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcIndexedPolygonalFace_CoordIndex_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcManifoldSolidBrep" name="IfcManifoldSolidBrep" isAbstract="true">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcManifoldSolidBrep_gen_IfcSolidModel" general="cl_IfcSolidModel"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcManifoldSolidBrep_Outer" name="Outer" association="as_IfcManifoldSolidBrep_Outer">
        <type xmi:type="uml:Class" href="IfcTopologyResource.uml#cl_IfcClosedShell"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcManifoldSolidBrep_Outer_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcManifoldSolidBrep_Outer_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcPolygonalBoundedHalfSpace" name="IfcPolygonalBoundedHalfSpace">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPolygonalBoundedHalfSpace_BoundaryDim" name="BoundaryDim">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcPolygonalBoundedHalfSpace_BoundaryDim" name="BoundaryDim">
          <language>EXPRESS_WHERE</language>
          <body>PolygonalBoundary.Dim = 2</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPolygonalBoundedHalfSpace_BoundaryType" name="BoundaryType">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcPolygonalBoundedHalfSpace_BoundaryType" name="BoundaryType">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(TYPEOF(PolygonalBoundary) * [
    'IFC4X3_ADD2.IFCPOLYLINE',
    'IFC4X3_ADD2.IFCCOMPOSITECURVE',
    'IFC4X3_ADD2.IFCINDEXEDPOLYCURVE'
  ]) = 1</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcPolygonalBoundedHalfSpace_gen_IfcHalfSpaceSolid" general="cl_IfcHalfSpaceSolid"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPolygonalBoundedHalfSpace_Position" name="Position" association="as_IfcPolygonalBoundedHalfSpace_Position">
        <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcAxis2Placement3D"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcPolygonalBoundedHalfSpace_Position_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPolygonalBoundedHalfSpace_Position_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPolygonalBoundedHalfSpace_PolygonalBoundary" name="PolygonalBoundary" association="as_IfcPolygonalBoundedHalfSpace_PolygonalBoundary">
        <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcBoundedCurve"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcPolygonalBoundedHalfSpace_PolygonalBoundary_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPolygonalBoundedHalfSpace_PolygonalBoundary_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcRectangularPyramid" name="IfcRectangularPyramid">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcRectangularPyramid_gen_IfcCsgPrimitive3D" general="cl_IfcCsgPrimitive3D"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRectangularPyramid_XLength" name="XLength">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcRectangularPyramid_XLength_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcRectangularPyramid_XLength_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRectangularPyramid_YLength" name="YLength">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcRectangularPyramid_YLength_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcRectangularPyramid_YLength_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRectangularPyramid_Height" name="Height">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcRectangularPyramid_Height_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcRectangularPyramid_Height_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcRightCircularCone" name="IfcRightCircularCone">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcRightCircularCone_gen_IfcCsgPrimitive3D" general="cl_IfcCsgPrimitive3D"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRightCircularCone_Height" name="Height">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcRightCircularCone_Height_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcRightCircularCone_Height_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRightCircularCone_BottomRadius" name="BottomRadius">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcRightCircularCone_BottomRadius_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcRightCircularCone_BottomRadius_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcRightCircularCylinder" name="IfcRightCircularCylinder">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcRightCircularCylinder_gen_IfcCsgPrimitive3D" general="cl_IfcCsgPrimitive3D"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRightCircularCylinder_Height" name="Height">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcRightCircularCylinder_Height_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcRightCircularCylinder_Height_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRightCircularCylinder_Radius" name="Radius">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcRightCircularCylinder_Radius_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcRightCircularCylinder_Radius_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcSectionedSolid" name="IfcSectionedSolid" isAbstract="true">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSolid_ConsistentProfileTypes" name="ConsistentProfileTypes">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcSectionedSolid_ConsistentProfileTypes" name="ConsistentProfileTypes">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(temp &lt;* CrossSections | CrossSections[1].ProfileType &lt;&gt; temp.ProfileType)) = 0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSolid_DirectrixIs3D" name="DirectrixIs3D">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcSectionedSolid_DirectrixIs3D" name="DirectrixIs3D">
          <language>EXPRESS_WHERE</language>
          <body>Directrix.Dim = 3</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSolid_SectionsSameType" name="SectionsSameType">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcSectionedSolid_SectionsSameType" name="SectionsSameType">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(temp &lt;* CrossSections | TYPEOF(CrossSections[1]) :&lt;&gt;: TYPEOF(temp))) = 0</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcSectionedSolid_gen_IfcSolidModel" general="cl_IfcSolidModel"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSectionedSolid_Directrix" name="Directrix" association="as_IfcSectionedSolid_Directrix">
        <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcCurve"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcSectionedSolid_Directrix_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcSectionedSolid_Directrix_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSectionedSolid_CrossSections" name="CrossSections_L[2:?]" association="as_IfcSectionedSolid_CrossSections">
        <type xmi:type="uml:Class" href="IfcProfileResource.uml#cl_IfcProfileDef"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcSectionedSolid_CrossSections_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcSectionedSolid_CrossSections_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcSectionedSurface" name="IfcSectionedSurface">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSurface_AreaProfileTypes" name="AreaProfileTypes">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcSectionedSurface_AreaProfileTypes" name="AreaProfileTypes">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(temp &lt;* CrossSections | temp.ProfileType = IfcProfileTypeEnum.CURVE)) &lt;&gt; 0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSurface_CorrespondingSectionPositions" name="CorrespondingSectionPositions">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcSectionedSurface_CorrespondingSectionPositions" name="CorrespondingSectionPositions">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(CrossSections) = SIZEOF(CrossSectionPositions)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSurface_DirectrixIs3D" name="DirectrixIs3D">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcSectionedSurface_DirectrixIs3D" name="DirectrixIs3D">
          <language>EXPRESS_WHERE</language>
          <body>Directrix.Dim = 3</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSurface_NoOffsets" name="NoOffsets">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcSectionedSurface_NoOffsets" name="NoOffsets">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(temp &lt;* CrossSectionPositions | EXISTS(temp.Location.OffsetLateral) OR EXISTS(temp.Location.OffsetVertical) OR EXISTS(temp.Location.OffsetLongitudinal))) = 0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSurface_SectionsSameType" name="SectionsSameType">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcSectionedSurface_SectionsSameType" name="SectionsSameType">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(temp &lt;* CrossSections | TYPEOF(CrossSections[1]) :&lt;&gt;: TYPEOF(temp))) = 0</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcSectionedSurface_gen_IfcSurface">
