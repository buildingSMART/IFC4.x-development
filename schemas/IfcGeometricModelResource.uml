        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcTriangulatedFaceSet_CoordIndex_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcTriangulatedFaceSet_CoordIndex_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcTriangulatedFaceSet_PnIndex" name="PnIndex_L[1:?]">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveInteger"/>
