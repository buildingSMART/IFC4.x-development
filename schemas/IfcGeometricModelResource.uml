      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcTriangulatedFaceSet_NumberOfTriangles" name="NumberOfTriangles" isDerived="true">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcInteger"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcTriangulatedFaceSet_NumberOfTriangles_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcTriangulatedFaceSet_NumberOfTriangles_upper" value="1"/>
        <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="at_IfcTriangulatedFaceSet_NumberOfTriangles_expr" name="NumberOfTriangles">
          <language>EXPRESS</language>
          <body>IfcInteger := SIZEOF(CoordIndex)</body>
        </defaultValue>
      </ownedAttribute>
