    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcSolidModel" name="IfcSolidModel" isAbstract="true">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcSolidModel_gen_IfcGeometricRepresentationItem">
