        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcSectionedSurface_Directrix_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcSectionedSurface_Directrix_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSectionedSurface_CrossSectionPositions" name="CrossSectionPositions_L[2:?]" association="as_IfcSectionedSurface_CrossSectionPositions">
