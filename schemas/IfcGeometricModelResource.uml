      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcDirectrixCurveSweptAreaSolid_EndParam" name="EndParam" association="as_IfcDirectrixCurveSweptAreaSolid_EndParam">
        <type xmi:type="uml:Class" href="IfcGeometryResource.uml#un_IfcCurveMeasureSelect"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcDirectrixCurveSweptAreaSolid_EndParam_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcDirectrixCurveSweptAreaSolid_EndParam_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcExtrudedAreaSolid" name="IfcExtrudedAreaSolid">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcExtrudedAreaSolid_ValidExtrusionDirection" name="ValidExtrusionDirection">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcExtrudedAreaSolid_ValidExtrusionDirection" name="ValidExtrusionDirection">
          <language>EXPRESS_WHERE</language>
          <body>IfcDotProduct(IfcRepresentationItem() || IfcGeometricRepresentationItem() || IfcDirection([0.0,0.0,1.0]), SELF.ExtrudedDirection) &lt;&gt; 0.0</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcExtrudedAreaSolid_gen_IfcSweptAreaSolid" general="cl_IfcSweptAreaSolid"/>
