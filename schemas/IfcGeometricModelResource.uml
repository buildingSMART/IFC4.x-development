    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcSweptAreaSolid" name="IfcSweptAreaSolid" isAbstract="true">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSweptAreaSolid_SweptAreaType" name="SweptAreaType">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcSweptAreaSolid_SweptAreaType" name="SweptAreaType">
          <language>EXPRESS_WHERE</language>
          <body>SweptArea.ProfileType = IfcProfileTypeEnum.Area</body>
        </specification>
