    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcSweptDiskSolidPolygonal" name="IfcSweptDiskSolidPolygonal">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSweptDiskSolidPolygonal_CorrectRadii" name="CorrectRadii">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcSweptDiskSolidPolygonal_CorrectRadii" name="CorrectRadii">
          <language>EXPRESS_WHERE</language>
          <body>NOT(EXISTS(FilletRadius)) OR (FilletRadius &gt;= SELF\IfcSweptDiskSolid.Radius)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSweptDiskSolidPolygonal_DirectrixIsPolyline" name="DirectrixIsPolyline">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcSweptDiskSolidPolygonal_DirectrixIsPolyline" name="DirectrixIsPolyline">
          <language>EXPRESS_WHERE</language>
          <body>('IFC4X3_ADD2.IFCPOLYLINE' IN TYPEOF(SELF\IfcSweptDiskSolid.Directrix)) OR
(('IFC4X3_ADD2.IFCINDEXEDPOLYCURVE' IN TYPEOF(SELF\IfcSweptDiskSolid.Directrix)) AND NOT(EXISTS(SELF\IfcSweptDiskSolid.Directrix\IfcIndexedPolyCurve.Segments)))</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcSweptDiskSolidPolygonal_gen_IfcSweptDiskSolid" general="cl_IfcSweptDiskSolid"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSweptDiskSolidPolygonal_FilletRadius" name="FilletRadius">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcNonNegativeLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcSweptDiskSolidPolygonal_FilletRadius_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcSweptDiskSolidPolygonal_FilletRadius_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
