        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcSweptDiskSolid_InnerRadius_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSweptDiskSolid_StartParam" name="StartParam">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcParameterValue"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcSweptDiskSolid_StartParam_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcSweptDiskSolid_StartParam_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSweptDiskSolid_EndParam" name="EndParam">
