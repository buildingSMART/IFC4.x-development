        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcGeometricSet_Dim_upper" value="1"/>
        <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="at_IfcGeometricSet_Dim_expr" name="Dim">
