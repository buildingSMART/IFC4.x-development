        <type xmi:type="uml:Class" href="IfcProfileResource.uml#cl_IfcProfileDef"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcSectionedSurface_CrossSections_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcSectionedSurface_CrossSections_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcSphere" name="IfcSphere">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcSphere_gen_IfcCsgPrimitive3D" general="cl_IfcCsgPrimitive3D"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSphere_Radius" name="Radius">
