        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveInteger"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcPolygonalFaceSet_PnIndex_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPolygonalFaceSet_PnIndex_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcRevolvedAreaSolid" name="IfcRevolvedAreaSolid">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRevolvedAreaSolid_AxisDirectionInXY" name="AxisDirectionInXY">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcRevolvedAreaSolid_AxisDirectionInXY" name="AxisDirectionInXY">
          <language>EXPRESS_WHERE</language>
          <body>Axis.Z.DirectionRatios[3] = 0.0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRevolvedAreaSolid_AxisStartInXY" name="AxisStartInXY">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcRevolvedAreaSolid_AxisStartInXY" name="AxisStartInXY">
          <language>EXPRESS_WHERE</language>
          <body>('IFC4X3_ADD2.IFCCARTESIANPOINT' IN TYPEOF(Axis.Location)) AND (Axis.Location\IfcCartesianPoint.Coordinates[3] = 0.0)</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcRevolvedAreaSolid_gen_IfcSweptAreaSolid" general="cl_IfcSweptAreaSolid"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRevolvedAreaSolid_Axis" name="Axis" association="as_IfcRevolvedAreaSolid_Axis">
        <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcAxis1Placement"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcRevolvedAreaSolid_Axis_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcRevolvedAreaSolid_Axis_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRevolvedAreaSolid_Angle" name="Angle">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPlaneAngleMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcRevolvedAreaSolid_Angle_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcRevolvedAreaSolid_Angle_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRevolvedAreaSolid_AxisLine" name="AxisLine" isDerived="true">
        <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcLine"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcRevolvedAreaSolid_AxisLine_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcRevolvedAreaSolid_AxisLine_upper" value="1"/>
        <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="at_IfcRevolvedAreaSolid_AxisLine_expr" name="AxisLine">
          <language>EXPRESS</language>
          <body>IfcLine := IfcRepresentationItem() || IfcGeometricRepresentationItem () || IfcCurve() || IfcLine(Axis.Location, 
  IfcRepresentationItem() || IfcGeometricRepresentationItem () || IfcVector(Axis.Z,1.0))</body>
        </defaultValue>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcSectionedSolidHorizontal" name="IfcSectionedSolidHorizontal">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSolidHorizontal_CorrespondingSectionPositions" name="CorrespondingSectionPositions">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcSectionedSolidHorizontal_CorrespondingSectionPositions" name="CorrespondingSectionPositions">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(CrossSections) = SIZEOF(CrossSectionPositions)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSolidHorizontal_NoLongitudinalOffsets" name="NoLongitudinalOffsets">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcSectionedSolidHorizontal_NoLongitudinalOffsets" name="NoLongitudinalOffsets">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(temp &lt;* CrossSectionPositions | EXISTS(temp.Location.OffsetLongitudinal))) = 0</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcSectionedSolidHorizontal_gen_IfcSectionedSolid" general="cl_IfcSectionedSolid"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSectionedSolidHorizontal_CrossSectionPositions" name="CrossSectionPositions_L[2:?]" association="as_IfcSectionedSolidHorizontal_CrossSectionPositions">
        <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcAxis2PlacementLinear"/>
