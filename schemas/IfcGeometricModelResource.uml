      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcTessellatedFaceSet_Coordinates" name="Coordinates" type="cl_IfcCartesianPointList3D" association="as_IfcTessellatedFaceSet_Coordinates">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcTessellatedFaceSet_Coordinates_lower" value="1"/>
