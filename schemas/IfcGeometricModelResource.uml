    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcAdvancedBrepWithVoids" name="IfcAdvancedBrepWithVoids">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcAdvancedBrepWithVoids_VoidsHaveAdvancedFaces" name="VoidsHaveAdvancedFaces">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcAdvancedBrepWithVoids_VoidsHaveAdvancedFaces" name="VoidsHaveAdvancedFaces">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF (QUERY (Vsh &lt;* Voids |
  SIZEOF (QUERY (Afs &lt;* Vsh.CfsFaces |
  (NOT ('IFC4X3_ADD2.IFCADVANCEDFACE' IN TYPEOF(Afs)))
  )) = 0
)) = 0</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcAdvancedBrepWithVoids_gen_IfcAdvancedBrep" general="cl_IfcAdvancedBrep"/>
