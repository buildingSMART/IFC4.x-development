    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcSweptDiskSolid" name="IfcSweptDiskSolid">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSweptDiskSolid_DirectrixBounded" name="DirectrixBounded">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcSweptDiskSolid_DirectrixBounded" name="DirectrixBounded">
          <language>EXPRESS_WHERE</language>
          <body>(EXISTS(StartParam) AND EXISTS(EndParam)) OR 
(SIZEOF(['IFC4X3_ADD2.IFCCONIC', 'IFC4X3_ADD2.IFCBOUNDEDCURVE'] * TYPEOF(Directrix)) = 1)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSweptDiskSolid_DirectrixDim" name="DirectrixDim">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcSweptDiskSolid_DirectrixDim" name="DirectrixDim">
          <language>EXPRESS_WHERE</language>
          <body>Directrix.Dim = 3</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSweptDiskSolid_InnerRadiusSize" name="InnerRadiusSize">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcSweptDiskSolid_InnerRadiusSize" name="InnerRadiusSize">
          <language>EXPRESS_WHERE</language>
          <body>(NOT EXISTS(InnerRadius)) OR (Radius &gt; InnerRadius)</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcSweptDiskSolid_gen_IfcSolidModel" general="cl_IfcSolidModel"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSweptDiskSolid_Directrix" name="Directrix" association="as_IfcSweptDiskSolid_Directrix">
        <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcCurve"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcSweptDiskSolid_Directrix_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcSweptDiskSolid_Directrix_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSweptDiskSolid_Radius" name="Radius">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcSweptDiskSolid_Radius_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcSweptDiskSolid_Radius_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSweptDiskSolid_InnerRadius" name="InnerRadius">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
