        <type xmi:type="uml:Class" href="IfcGeometryResource.uml#un_IfcCurveMeasureSelect"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcDirectrixCurveSweptAreaSolid_StartParam_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcDirectrixCurveSweptAreaSolid_StartParam_upper" value="1"/>
