<?xml version="1.0" encoding="UTF-8"?>
<uml:Model xmlns:uml="http://www.eclipse.org/uml2/5.0.0/UML" xmlns:xmi="http://www.omg.org/spec/XMI/20131001" xmi:id="md_IfcGeometricModelResource" name="IfcGeometricModelResource" xmi:version="20131001">
  <packagedElement xmi:type="uml:Package" xmi:id="pk_IfcGeometricModelResource" name="IfcGeometricModelResource">
    <packagedElement xmi:type="uml:Constraint" xmi:id="ct_IfcPointListDim" name="IfcPointListDim">
      <specification xmi:type="uml:OpaqueExpression" xmi:id="ct_IfcPointListDim_expr" name="IfcPointListDim">
        <language>EXPRESS_FUNCTION</language>
        <body>FUNCTION IfcPointListDim
(PointList : IfcCartesianPointList)
           : IfcDimensionCount;

  IF ('IFC4X3_ADD2.IFCCARTESIANPOINTLIST2D' IN TYPEOF(PointList))
    THEN RETURN(2);
  END_IF;     
  IF ('IFC4X3_ADD2.IFCCARTESIANPOINTLIST3D' IN TYPEOF(PointList))
    THEN RETURN(3);
  END_IF;     
  RETURN (?);

END_FUNCTION;
</body>
      </specification>
    </packagedElement>
    <packagedElement xmi:type="uml:Constraint" xmi:id="ct_IfcTaperedSweptAreaProfiles" name="IfcTaperedSweptAreaProfiles">
      <specification xmi:type="uml:OpaqueExpression" xmi:id="ct_IfcTaperedSweptAreaProfiles_expr" name="IfcTaperedSweptAreaProfiles">
        <language>EXPRESS_FUNCTION</language>
        <body>FUNCTION IfcTaperedSweptAreaProfiles
(StartArea, EndArea : IfcProfileDef)
 : LOGICAL;

LOCAL
   Result : LOGICAL := FALSE;
END_LOCAL;
   
IF ('IFC4X3_ADD2.IFCPARAMETERIZEDPROFILEDEF' IN TYPEOF(StartArea)) THEN
   IF ('IFC4X3_ADD2.IFCDERIVEDPROFILEDEF' IN TYPEOF(EndArea)) THEN
      Result := (StartArea :=: EndArea\IfcDerivedProfileDef.ParentProfile);
   ELSE
      Result := (TYPEOF(StartArea) = TYPEOF(EndArea));
   END_IF;
ELSE
   IF ('IFC4X3_ADD2.IFCDERIVEDPROFILEDEF' IN TYPEOF(EndArea)) THEN
      Result := (StartArea :=: EndArea\IfcDerivedProfileDef.ParentProfile);
   ELSE
      Result := FALSE;
   END_IF;
END_IF;

RETURN(Result);

END_FUNCTION;
</body>
      </specification>
    </packagedElement>
    <packagedElement xmi:type="uml:Enumeration" xmi:id="en_IfcBooleanOperator" name="IfcBooleanOperator">
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcBooleanOperator_DIFFERENCE" name="DIFFERENCE"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcBooleanOperator_INTERSECTION" name="INTERSECTION"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcBooleanOperator_UNION" name="UNION"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcBooleanResult" name="IfcBooleanResult">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcBooleanResult_FirstOperandClosed" name="FirstOperandClosed">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcBooleanResult_FirstOperandClosed" name="FirstOperandClosed">
          <language>EXPRESS_WHERE</language>
          <body>NOT('IFC4X3_ADD2.IFCTESSELLATEDFACESET' IN TYPEOF(FirstOperand)) OR (EXISTS(FirstOperand.Closed) AND FirstOperand.Closed)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcBooleanResult_SameDim" name="SameDim">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcBooleanResult_SameDim" name="SameDim">
          <language>EXPRESS_WHERE</language>
          <body>FirstOperand.Dim = SecondOperand.Dim</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcBooleanResult_SecondOperandClosed" name="SecondOperandClosed">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcBooleanResult_SecondOperandClosed" name="SecondOperandClosed">
          <language>EXPRESS_WHERE</language>
          <body>NOT('IFC4X3_ADD2.IFCTESSELLATEDFACESET' IN TYPEOF(SecondOperand)) OR (EXISTS(SecondOperand.Closed) AND SecondOperand.Closed)</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcBooleanResult_gen_IfcGeometricRepresentationItem">
        <general xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcGeometricRepresentationItem"/>
      </generalization>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcBooleanResult_Operator" name="Operator" type="en_IfcBooleanOperator">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcBooleanResult_Operator_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcBooleanResult_Operator_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcBooleanResult_FirstOperand" name="FirstOperand" type="un_IfcBooleanOperand" association="as_IfcBooleanResult_FirstOperand">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcBooleanResult_FirstOperand_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcBooleanResult_FirstOperand_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcBooleanResult_SecondOperand" name="SecondOperand" type="un_IfcBooleanOperand" association="as_IfcBooleanResult_SecondOperand">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcBooleanResult_SecondOperand_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcBooleanResult_SecondOperand_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcBooleanResult_Dim" name="Dim" isDerived="true">
        <type xmi:type="uml:DataType" href="IfcGeometryResource.uml#dt_IfcDimensionCount"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcBooleanResult_Dim_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcBooleanResult_Dim_upper" value="1"/>
        <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="at_IfcBooleanResult_Dim_expr" name="Dim">
          <language>EXPRESS</language>
          <body>IfcDimensionCount := FirstOperand.Dim</body>
        </defaultValue>
      </ownedAttribute>
    </packagedElement>
