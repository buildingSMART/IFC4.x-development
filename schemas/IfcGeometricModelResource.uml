    <packagedElement xmi:type="uml:Dependency" xmi:id="dp_IfcBooleanOperand_IfcCsgPrimitive3D" client="un_IfcBooleanOperand" supplier="cl_IfcCsgPrimitive3D"/>
    <packagedElement xmi:type="uml:Dependency" xmi:id="dp_IfcBooleanOperand_IfcHalfSpaceSolid" client="un_IfcBooleanOperand" supplier="cl_IfcHalfSpaceSolid"/>
