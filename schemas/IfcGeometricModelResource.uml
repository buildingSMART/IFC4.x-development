          <language>EXPRESS</language>
          <body>IfcDimensionCount := 3</body>
        </defaultValue>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcAdvancedBrep" name="IfcAdvancedBrep">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcAdvancedBrep_HasAdvancedFaces" name="HasAdvancedFaces">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcAdvancedBrep_HasAdvancedFaces" name="HasAdvancedFaces">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(Afs &lt;* SELF\IfcManifoldSolidBrep.Outer.CfsFaces |
  (NOT ('IFC4X3_ADD2.IFCADVANCEDFACE' IN TYPEOF(Afs)))
)) = 0</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcAdvancedBrep_gen_IfcManifoldSolidBrep" general="cl_IfcManifoldSolidBrep"/>
    </packagedElement>
