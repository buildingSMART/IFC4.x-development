    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcSectionedSpine" name="IfcSectionedSpine">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSpine_ConsistentProfileTypes" name="ConsistentProfileTypes">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcSectionedSpine_ConsistentProfileTypes" name="ConsistentProfileTypes">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(temp &lt;* CrossSections | CrossSections[1].ProfileType &lt;&gt; temp.ProfileType)) = 0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSpine_CorrespondingSectionPositions" name="CorrespondingSectionPositions">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcSectionedSpine_CorrespondingSectionPositions" name="CorrespondingSectionPositions">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(CrossSections) = SIZEOF(CrossSectionPositions)</body>
