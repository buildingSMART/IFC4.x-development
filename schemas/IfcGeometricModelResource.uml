      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSolidModel_Dim" name="Dim" isDerived="true">
        <type xmi:type="uml:DataType" href="IfcGeometryResource.uml#dt_IfcDimensionCount"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcSolidModel_Dim_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcSolidModel_Dim_upper" value="1"/>
        <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="at_IfcSolidModel_Dim_expr" name="Dim">
          <language>EXPRESS</language>
          <body>IfcDimensionCount := 3</body>
        </defaultValue>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcTessellatedItem" name="IfcTessellatedItem" isAbstract="true">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcTessellatedItem_gen_IfcGeometricRepresentationItem">
        <general xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcGeometricRepresentationItem"/>
      </generalization>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcBlock" name="IfcBlock">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcBlock_gen_IfcCsgPrimitive3D" general="cl_IfcCsgPrimitive3D"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcBlock_XLength" name="XLength">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcBlock_XLength_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcBlock_XLength_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcBlock_YLength" name="YLength">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcBlock_YLength_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcBlock_YLength_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcBlock_ZLength" name="ZLength">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcBlock_ZLength_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcBlock_ZLength_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcBooleanClippingResult" name="IfcBooleanClippingResult">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcBooleanClippingResult_FirstOperandType" name="FirstOperandType">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcBooleanClippingResult_FirstOperandType" name="FirstOperandType">
          <language>EXPRESS_WHERE</language>
          <body>('IFC4X3_ADD2.IFCSWEPTAREASOLID' IN TYPEOF(FirstOperand)) OR 
('IFC4X3_ADD2.IFCSWEPTDISCSOLID' IN TYPEOF(FirstOperand)) OR 
('IFC4X3_ADD2.IFCBOOLEANCLIPPINGRESULT' IN TYPEOF(FirstOperand))</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcBooleanClippingResult_OperatorType" name="OperatorType">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcBooleanClippingResult_OperatorType" name="OperatorType">
          <language>EXPRESS_WHERE</language>
          <body>Operator = DIFFERENCE</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcBooleanClippingResult_SecondOperandType" name="SecondOperandType">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcBooleanClippingResult_SecondOperandType" name="SecondOperandType">
          <language>EXPRESS_WHERE</language>
          <body>('IFC4X3_ADD2.IFCHALFSPACESOLID' IN TYPEOF(SecondOperand))</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcBooleanClippingResult_gen_IfcBooleanResult" general="cl_IfcBooleanResult"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcBoxedHalfSpace" name="IfcBoxedHalfSpace">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcBoxedHalfSpace_UnboundedSurface" name="UnboundedSurface">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcBoxedHalfSpace_UnboundedSurface" name="UnboundedSurface">
          <language>EXPRESS_WHERE</language>
          <body>NOT ('IFC4X3_ADD2.IFCCURVEBOUNDEDPLANE' IN TYPEOF(SELF\IfcHalfSpaceSolid.BaseSurface))</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcBoxedHalfSpace_gen_IfcHalfSpaceSolid" general="cl_IfcHalfSpaceSolid"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcBoxedHalfSpace_Enclosure" name="Enclosure" type="cl_IfcBoundingBox" association="as_IfcBoxedHalfSpace_Enclosure">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcBoxedHalfSpace_Enclosure_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcBoxedHalfSpace_Enclosure_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
