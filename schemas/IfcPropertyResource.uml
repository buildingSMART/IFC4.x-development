        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcExtendedProperties_Properties_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="un_IfcObjectReferenceSelect" name="IfcObjectReferenceSelect"/>
