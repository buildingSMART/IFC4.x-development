<?xml version="1.0" encoding="UTF-8"?>
<uml:Model xmlns:uml="http://www.eclipse.org/uml2/5.0.0/UML" xmlns:xmi="http://www.omg.org/spec/XMI/20131001" xmi:id="md_IfcPropertyResource" name="IfcPropertyResource" xmi:version="20131001">
  <packagedElement xmi:type="uml:Package" xmi:id="pk_IfcPropertyResource" name="IfcPropertyResource">
    <packagedElement xmi:type="uml:Enumeration" xmi:id="en_IfcCurveInterpolationEnum" name="IfcCurveInterpolationEnum">
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcCurveInterpolationEnum_LINEAR" name="LINEAR"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcCurveInterpolationEnum_LOG_LINEAR" name="LOG_LINEAR"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcCurveInterpolationEnum_LOG_LOG" name="LOG_LOG"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcCurveInterpolationEnum_NOTDEFINED" name="NOTDEFINED"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcPropertyAbstraction" name="IfcPropertyAbstraction" isAbstract="true"/>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcExtendedProperties" name="IfcExtendedProperties" isAbstract="true">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcExtendedProperties_gen_IfcPropertyAbstraction" general="cl_IfcPropertyAbstraction"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcExtendedProperties_Name" name="Name">
