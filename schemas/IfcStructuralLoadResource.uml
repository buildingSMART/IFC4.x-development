    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcStructuralLoadConfiguration" name="IfcStructuralLoadConfiguration">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcStructuralLoadConfiguration_ValidListSize" name="ValidListSize">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcStructuralLoadConfiguration_ValidListSize" name="ValidListSize">
          <language>EXPRESS_WHERE</language>
          <body>NOT EXISTS(Locations) OR (SIZEOF(Locations) = SIZEOF(Values))</body>
