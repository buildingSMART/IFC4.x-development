      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcStructuralLoadConfiguration_gen_IfcStructuralLoad" general="cl_IfcStructuralLoad"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcStructuralLoadConfiguration_Values" name="Values_L[1:?]" type="cl_IfcStructuralLoadOrResult" association="as_IfcStructuralLoadConfiguration_Values">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcStructuralLoadConfiguration_Values_lower" value="1"/>
