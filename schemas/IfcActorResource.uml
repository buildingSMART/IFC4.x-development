      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPerson_Roles" name="Roles_L[1:?]" type="cl_IfcActorRole" association="as_IfcPerson_Roles">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcPerson_Roles_lower"/>
