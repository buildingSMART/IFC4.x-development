        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcText"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcOrganization_Description_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcOrganization_Description_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOrganization_Roles" name="Roles_L[1:?]" type="cl_IfcActorRole" association="as_IfcOrganization_Roles">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcOrganization_Roles_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcOrganization_Roles_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOrganization_Addresses" name="Addresses_L[1:?]" type="cl_IfcAddress" association="as_IfcOrganization_Addresses">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcOrganization_Addresses_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcOrganization_Addresses_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcPerson" name="IfcPerson">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPerson_IdentifiablePerson" name="IdentifiablePerson">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcPerson_IdentifiablePerson" name="IdentifiablePerson">
          <language>EXPRESS_WHERE</language>
          <body>EXISTS(Identification) OR EXISTS(FamilyName) OR EXISTS(GivenName)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPerson_ValidSetOfNames" name="ValidSetOfNames">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcPerson_ValidSetOfNames" name="ValidSetOfNames">
          <language>EXPRESS_WHERE</language>
          <body>NOT EXISTS(MiddleNames) OR EXISTS(FamilyName) OR EXISTS(GivenName)</body>
        </specification>
      </ownedRule>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPerson_Identification" name="Identification">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcIdentifier"/>
