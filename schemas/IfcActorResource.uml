      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPerson_Addresses" name="Addresses_L[1:?]" type="cl_IfcAddress" association="as_IfcPerson_Addresses">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcPerson_Addresses_lower"/>
