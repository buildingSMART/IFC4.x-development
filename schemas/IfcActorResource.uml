<?xml version="1.0" encoding="UTF-8"?>
<uml:Model xmlns:uml="http://www.eclipse.org/uml2/5.0.0/UML" xmlns:xmi="http://www.omg.org/spec/XMI/20131001" xmi:id="md_IfcActorResource" name="IfcActorResource" xmi:version="20131001">
  <packagedElement xmi:type="uml:Package" xmi:id="pk_IfcActorResource" name="IfcActorResource">
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcActorRole" name="IfcActorRole">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcActorRole_WR1" name="WR1">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcActorRole_WR1" name="WR1">
          <language>EXPRESS_WHERE</language>
          <body>(Role &lt;&gt; IfcRoleEnum.USERDEFINED) OR
((Role = IfcRoleEnum.USERDEFINED) AND
  EXISTS(SELF.UserDefinedRole))</body>
        </specification>
      </ownedRule>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcActorRole_Role" name="Role" type="en_IfcRoleEnum">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcActorRole_Role_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcActorRole_Role_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcActorRole_UserDefinedRole" name="UserDefinedRole">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcActorRole_UserDefinedRole_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcActorRole_UserDefinedRole_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcActorRole_Description" name="Description">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcText"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcActorRole_Description_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcActorRole_Description_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcAddress" name="IfcAddress" isAbstract="true">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcAddress_WR1" name="WR1">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcAddress_WR1" name="WR1">
          <language>EXPRESS_WHERE</language>
          <body>(NOT(EXISTS(Purpose))) OR
((Purpose &lt;&gt; IfcAddressTypeEnum.USERDEFINED) OR
((Purpose = IfcAddressTypeEnum.USERDEFINED) AND
  EXISTS(SELF.UserDefinedPurpose)))</body>
        </specification>
      </ownedRule>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAddress_Purpose" name="Purpose" type="en_IfcAddressTypeEnum">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcAddress_Purpose_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcAddress_Purpose_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAddress_Description" name="Description">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcText"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcAddress_Description_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcAddress_Description_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAddress_UserDefinedPurpose" name="UserDefinedPurpose">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcAddress_UserDefinedPurpose_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcAddress_UserDefinedPurpose_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Enumeration" xmi:id="en_IfcAddressTypeEnum" name="IfcAddressTypeEnum">
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcAddressTypeEnum_DISTRIBUTIONPOINT" name="DISTRIBUTIONPOINT"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcAddressTypeEnum_HOME" name="HOME"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcAddressTypeEnum_OFFICE" name="OFFICE"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcAddressTypeEnum_SITE" name="SITE"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcAddressTypeEnum_USERDEFINED" name="USERDEFINED"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcOrganization" name="IfcOrganization">
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOrganization_Identification" name="Identification">
