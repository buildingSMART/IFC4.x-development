        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcTelecomAddress_TelephoneNumbers_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcTelecomAddress_TelephoneNumbers_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcTelecomAddress_FacsimileNumbers" name="FacsimileNumbers_L[1:?]">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcTelecomAddress_FacsimileNumbers_lower"/>
