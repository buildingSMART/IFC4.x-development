    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcPostalAddress" name="IfcPostalAddress">
      <ownedComment xmi:type="uml:Comment" xmi:id="cl_IfcPostalAddress_comment_0">
        <body>DEPRECATED</body>
      </ownedComment>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPostalAddress_WR1" name="WR1">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcPostalAddress_WR1" name="WR1">
          <language>EXPRESS_WHERE</language>
          <body>EXISTS (InternalLocation) OR 
EXISTS (AddressLines) OR
EXISTS (PostalBox) OR
EXISTS (PostalCode) OR
EXISTS (Town) OR 
EXISTS (Region) OR  
EXISTS (Country)</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcPostalAddress_gen_IfcAddress" general="cl_IfcAddress"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPostalAddress_InternalLocation" name="InternalLocation">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcPostalAddress_InternalLocation_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPostalAddress_InternalLocation_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPostalAddress_AddressLines" name="AddressLines_L[1:?]">
