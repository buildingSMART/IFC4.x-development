        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPerson_GivenName_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPerson_MiddleNames" name="MiddleNames_L[1:?]">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcPerson_MiddleNames_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPerson_MiddleNames_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPerson_PrefixTitles" name="PrefixTitles_L[1:?]">
