        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPresentationLayerAssignment_Description_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPresentationLayerAssignment_AssignedItems" name="AssignedItems_S[1:?]" type="un_IfcLayeredItem" association="as_IfcPresentationLayerAssignment_AssignedItems">
