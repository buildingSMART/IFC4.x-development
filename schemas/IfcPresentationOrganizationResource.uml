    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcPresentationLayerAssignment" name="IfcPresentationLayerAssignment">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPresentationLayerAssignment_ApplicableItems" name="ApplicableItems">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcPresentationLayerAssignment_ApplicableItems" name="ApplicableItems">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(temp &lt;* AssignedItems | (
  SIZEOF(TYPEOF(temp) * [
    'IFC4X3_ADD2.IFCSHAPEREPRESENTATION',
    'IFC4X3_ADD2.IFCGEOMETRICREPRESENTATIONITEM',
    'IFC4X3_ADD2.IFCMAPPEDITEM']) = 1)
)) = SIZEOF(AssignedItems)</body>
        </specification>
      </ownedRule>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPresentationLayerAssignment_Name" name="Name">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcPresentationLayerAssignment_Name_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPresentationLayerAssignment_Name_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPresentationLayerAssignment_Description" name="Description">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcText"/>
