        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPresentationLayerAssignment_AssignedItems_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPresentationLayerAssignment_Identifier" name="Identifier">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcIdentifier"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcPresentationLayerAssignment_Identifier_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPresentationLayerAssignment_Identifier_upper" value="1"/>
