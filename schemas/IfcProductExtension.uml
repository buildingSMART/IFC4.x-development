        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcRelReferencedInSpatialStructure_RelatingStructure_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcRelServicesBuildings" name="IfcRelServicesBuildings">
      <ownedComment xmi:type="uml:Comment" xmi:id="cl_IfcRelServicesBuildings_comment_0">
