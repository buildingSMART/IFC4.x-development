    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcZone" name="IfcZone">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcZone_WR1" name="WR1">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcZone_WR1" name="WR1">
          <language>EXPRESS_WHERE</language>
          <body>(SIZEOF(SELF\IfcGroup.IsGroupedBy) = 0) OR
 (SIZEOF (QUERY (temp &lt;* SELF\IfcGroup.IsGroupedBy[1].RelatedObjects |  
  NOT(('IFC4X3_ADD2.IFCZONE' IN TYPEOF(temp)) OR 
  ('IFC4X3_ADD2.IFCSPACE' IN TYPEOF(temp)) OR
  ('IFC4X3_ADD2.IFCSPATIALZONE' IN TYPEOF(temp))
 ))) = 0)</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcZone_gen_IfcSystem" general="cl_IfcSystem"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcZone_LongName" name="LongName">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
