      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRelSpaceBoundary_RelatedBuildingElement" name="RelatedBuildingElement" type="cl_IfcElement" association="as_IfcRelSpaceBoundary_RelatedBuildingElement">
