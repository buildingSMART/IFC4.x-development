        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcRelProjectsElement_RelatedFeatureElement_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcRelProjectsElement_RelatedFeatureElement_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcRelReferencedInSpatialStructure" name="IfcRelReferencedInSpatialStructure">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRelReferencedInSpatialStructure_AllowedRelatedElements" name="AllowedRelatedElements">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcRelReferencedInSpatialStructure_AllowedRelatedElements" name="AllowedRelatedElements">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(temp &lt;* RelatedElements | ('IFC4X3_ADD2.IFCSPATIALSTRUCTUREELEMENT' IN TYPEOF(temp)) AND (NOT ('IFC4X3_ADD2.IFCSPACE' IN TYPEOF(temp)))
)) = 0</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcRelReferencedInSpatialStructure_gen_IfcRelConnects">
        <general xmi:type="uml:Class" href="IfcKernel.uml#cl_IfcRelConnects"/>
      </generalization>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRelReferencedInSpatialStructure_RelatedElements" name="RelatedElements_S[1:?]" type="un_IfcSpatialReferenceSelect" association="as_IfcRelReferencedInSpatialStructure_RelatedElements">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcRelReferencedInSpatialStructure_RelatedElements_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcRelReferencedInSpatialStructure_RelatedElements_upper" value="1"/>
      </ownedAttribute>
