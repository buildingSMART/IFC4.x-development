        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcProcess_LongDescription_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcProduct" name="IfcProduct" isAbstract="true">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcProduct_PlacementForShapeRepresentation" name="PlacementForShapeRepresentation">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcProduct_PlacementForShapeRepresentation" name="PlacementForShapeRepresentation">
          <language>EXPRESS_WHERE</language>
          <body>(EXISTS(Representation) AND EXISTS(ObjectPlacement))
            OR (EXISTS(Representation) AND 
      (SIZEOF(QUERY(temp &lt;* Representation.Representations | 'IFC4X3_ADD2.IFCSHAPEREPRESENTATION' IN TYPEOF(temp))) = 0))
            OR (NOT(EXISTS(Representation)))</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcProduct_gen_IfcObject" general="cl_IfcObject"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcProduct_ObjectPlacement" name="ObjectPlacement" association="as_IfcProduct_ObjectPlacement">
        <type xmi:type="uml:Class" href="IfcGeometricConstraintResource.uml#cl_IfcObjectPlacement"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcProduct_ObjectPlacement_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcProduct_ObjectPlacement_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcProduct_Representation" name="Representation" association="as_IfcProduct_Representation">
        <type xmi:type="uml:Class" href="IfcRepresentationResource.uml#cl_IfcProductRepresentation"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcProduct_Representation_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcProduct_Representation_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcProject" name="IfcProject">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcProject_CorrectContext" name="CorrectContext">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcProject_CorrectContext" name="CorrectContext">
          <language>EXPRESS_WHERE</language>
          <body>NOT(EXISTS(SELF\IfcContext.RepresentationContexts)) OR
(SIZEOF(QUERY(Temp &lt;* SELF\IfcContext.RepresentationContexts |
 'IFC4X3_ADD2.IFCGEOMETRICREPRESENTATIONSUBCONTEXT' IN TYPEOF(Temp)
  )) = 0)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcProject_HasName" name="HasName">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcProject_HasName" name="HasName">
          <language>EXPRESS_WHERE</language>
          <body>EXISTS(SELF\IfcRoot.Name)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcProject_NoDecomposition" name="NoDecomposition">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcProject_NoDecomposition" name="NoDecomposition">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(SELF\IfcObjectDefinition.Decomposes) = 0</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcProject_gen_IfcContext" general="cl_IfcContext"/>
    </packagedElement>
