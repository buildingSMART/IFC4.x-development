    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcRelDeclares" name="IfcRelDeclares">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRelDeclares_NoSelfReference" name="NoSelfReference">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcRelDeclares_NoSelfReference" name="NoSelfReference">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(Temp &lt;* RelatedDefinitions | RelatingContext :=: Temp)) = 0</body>
        </specification>
      </ownedRule>
