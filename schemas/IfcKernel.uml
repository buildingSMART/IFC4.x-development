    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcTypeObject" name="IfcTypeObject">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcTypeObject_NameRequired" name="NameRequired">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcTypeObject_NameRequired" name="NameRequired">
          <language>EXPRESS_WHERE</language>
          <body>EXISTS(SELF\IfcRoot.Name)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcTypeObject_UniquePropertySetNames" name="UniquePropertySetNames">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcTypeObject_UniquePropertySetNames" name="UniquePropertySetNames">
          <language>EXPRESS_WHERE</language>
          <body>(NOT(EXISTS(HasPropertySets))) OR IfcUniquePropertySetNames(HasPropertySets)</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcTypeObject_gen_IfcObjectDefinition" general="cl_IfcObjectDefinition"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcTypeObject_ApplicableOccurrence" name="ApplicableOccurrence">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcIdentifier"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcTypeObject_ApplicableOccurrence_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcTypeObject_ApplicableOccurrence_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcTypeObject_HasPropertySets" name="HasPropertySets_S[1:?]" type="cl_IfcPropertySetDefinition" association="as_IfcTypeObject_HasPropertySets">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcTypeObject_HasPropertySets_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcTypeObject_HasPropertySets_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcActor" name="IfcActor">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcActor_gen_IfcObject" general="cl_IfcObject"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcActor_TheActor" name="TheActor" association="as_IfcActor_TheActor">
        <type xmi:type="uml:Class" href="IfcActorResource.uml#un_IfcActorSelect"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcActor_TheActor_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcActor_TheActor_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcControl" name="IfcControl" isAbstract="true">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcControl_gen_IfcObject" general="cl_IfcObject"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcControl_Identification" name="Identification">
