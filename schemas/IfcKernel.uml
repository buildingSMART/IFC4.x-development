    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcObject" name="IfcObject" isAbstract="true">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcObject_UniquePropertySetNames" name="UniquePropertySetNames">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcObject_UniquePropertySetNames" name="UniquePropertySetNames">
          <language>EXPRESS_WHERE</language>
          <body>((SIZEOF(IsDefinedBy) = 0) OR IfcUniqueDefinitionNames(IsDefinedBy))</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcObject_gen_IfcObjectDefinition" general="cl_IfcObjectDefinition"/>
