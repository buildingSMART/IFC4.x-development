        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcProcess_Identification_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcProcess_LongDescription" name="LongDescription">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcText"/>
