        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcLShapeProfileDef_LegSlope_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcLShapeProfileDef_LegSlope_upper" value="1"/>
