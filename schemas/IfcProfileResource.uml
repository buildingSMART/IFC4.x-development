        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcRectangleHollowProfileDef_ValidOuterRadius" name="ValidOuterRadius">
          <language>EXPRESS_WHERE</language>
          <body>NOT(EXISTS(OuterFilletRadius)) OR 
((OuterFilletRadius &lt;= (SELF\IfcRectangleProfileDef.XDim/2.)) AND 
 (OuterFilletRadius &lt;= (SELF\IfcRectangleProfileDef.YDim/2.)))</body>
        </specification>
