<?xml version="1.0" encoding="UTF-8"?>
<uml:Model xmlns:uml="http://www.eclipse.org/uml2/5.0.0/UML" xmlns:xmi="http://www.omg.org/spec/XMI/20131001" xmi:id="md_IfcProfileResource" name="IfcProfileResource" xmi:version="20131001">
  <packagedElement xmi:type="uml:Package" xmi:id="pk_IfcProfileResource" name="IfcProfileResource">
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcProfileDef" name="IfcProfileDef">
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcProfileDef_ProfileType" name="ProfileType" type="en_IfcProfileTypeEnum">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcProfileDef_ProfileType_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcProfileDef_ProfileType_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcProfileDef_ProfileName" name="ProfileName">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcProfileDef_ProfileName_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcProfileDef_ProfileName_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Enumeration" xmi:id="en_IfcProfileTypeEnum" name="IfcProfileTypeEnum">
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcProfileTypeEnum_AREA" name="AREA"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcProfileTypeEnum_CURVE" name="CURVE"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Enumeration" xmi:id="en_IfcReinforcingBarRoleEnum" name="IfcReinforcingBarRoleEnum">
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcReinforcingBarRoleEnum_ANCHORING" name="ANCHORING"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcReinforcingBarRoleEnum_EDGE" name="EDGE"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcReinforcingBarRoleEnum_LIGATURE" name="LIGATURE"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcReinforcingBarRoleEnum_MAIN" name="MAIN"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcReinforcingBarRoleEnum_PUNCHING" name="PUNCHING"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcReinforcingBarRoleEnum_RING" name="RING"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcReinforcingBarRoleEnum_SHEAR" name="SHEAR"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcReinforcingBarRoleEnum_STUD" name="STUD"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcReinforcingBarRoleEnum_USERDEFINED" name="USERDEFINED"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcReinforcingBarRoleEnum_NOTDEFINED" name="NOTDEFINED"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Enumeration" xmi:id="en_IfcReinforcingBarSurfaceEnum" name="IfcReinforcingBarSurfaceEnum">
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcReinforcingBarSurfaceEnum_PLAIN" name="PLAIN"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcReinforcingBarSurfaceEnum_TEXTURED" name="TEXTURED"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Enumeration" xmi:id="en_IfcSectionTypeEnum" name="IfcSectionTypeEnum">
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcSectionTypeEnum_TAPERED" name="TAPERED"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcSectionTypeEnum_UNIFORM" name="UNIFORM"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcArbitraryClosedProfileDef" name="IfcArbitraryClosedProfileDef">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcArbitraryClosedProfileDef_WR1" name="WR1">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcArbitraryClosedProfileDef_WR1" name="WR1">
          <language>EXPRESS_WHERE</language>
          <body>OuterCurve.Dim = 2</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcArbitraryClosedProfileDef_WR2" name="WR2">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcArbitraryClosedProfileDef_WR2" name="WR2">
          <language>EXPRESS_WHERE</language>
          <body>NOT('IFC4X3_ADD2.IFCLINE' IN TYPEOF(OuterCurve))</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcArbitraryClosedProfileDef_WR3" name="WR3">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcArbitraryClosedProfileDef_WR3" name="WR3">
          <language>EXPRESS_WHERE</language>
          <body>NOT('IFC4X3_ADD2.IFCOFFSETCURVE2D' IN TYPEOF(OuterCurve))</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcArbitraryClosedProfileDef_gen_IfcProfileDef" general="cl_IfcProfileDef"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcArbitraryClosedProfileDef_OuterCurve" name="OuterCurve" association="as_IfcArbitraryClosedProfileDef_OuterCurve">
        <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcCurve"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcArbitraryClosedProfileDef_OuterCurve_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcArbitraryClosedProfileDef_OuterCurve_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcArbitraryOpenProfileDef" name="IfcArbitraryOpenProfileDef">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcArbitraryOpenProfileDef_WR11" name="WR11">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcArbitraryOpenProfileDef_WR11" name="WR11">
          <language>EXPRESS_WHERE</language>
          <body>('IFC4X3_ADD2.IFCCENTERLINEPROFILEDEF' IN TYPEOF(SELF)) OR 
 (SELF\IfcProfileDef.ProfileType = IfcProfileTypeEnum.CURVE)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcArbitraryOpenProfileDef_WR12" name="WR12">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcArbitraryOpenProfileDef_WR12" name="WR12">
          <language>EXPRESS_WHERE</language>
          <body>Curve.Dim = 2</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcArbitraryOpenProfileDef_gen_IfcProfileDef" general="cl_IfcProfileDef"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcArbitraryOpenProfileDef_Curve" name="Curve" association="as_IfcArbitraryOpenProfileDef_Curve">
        <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcBoundedCurve"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcArbitraryOpenProfileDef_Curve_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcArbitraryOpenProfileDef_Curve_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcCompositeProfileDef" name="IfcCompositeProfileDef">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCompositeProfileDef_InvariantProfileType" name="InvariantProfileType">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcCompositeProfileDef_InvariantProfileType" name="InvariantProfileType">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(temp &lt;* Profiles | temp.ProfileType &lt;&gt; Profiles[1].ProfileType)) = 0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCompositeProfileDef_NoRecursion" name="NoRecursion">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcCompositeProfileDef_NoRecursion" name="NoRecursion">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(temp &lt;* Profiles | 'IFC4X3_ADD2.IFCCOMPOSITEPROFILEDEF' IN TYPEOF(temp))) = 0</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcCompositeProfileDef_gen_IfcProfileDef" general="cl_IfcProfileDef"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCompositeProfileDef_Profiles" name="Profiles_S[2:?]" type="cl_IfcProfileDef" association="as_IfcCompositeProfileDef_Profiles">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCompositeProfileDef_Profiles_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCompositeProfileDef_Profiles_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCompositeProfileDef_Label" name="Label">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCompositeProfileDef_Label_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCompositeProfileDef_Label_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcDerivedProfileDef" name="IfcDerivedProfileDef">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcDerivedProfileDef_InvariantProfileType" name="InvariantProfileType">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcDerivedProfileDef_InvariantProfileType" name="InvariantProfileType">
          <language>EXPRESS_WHERE</language>
          <body>SELF\IfcProfileDef.ProfileType = ParentProfile.ProfileType</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcDerivedProfileDef_gen_IfcProfileDef" general="cl_IfcProfileDef"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcDerivedProfileDef_ParentProfile" name="ParentProfile" type="cl_IfcProfileDef" association="as_IfcDerivedProfileDef_ParentProfile">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcDerivedProfileDef_ParentProfile_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcDerivedProfileDef_ParentProfile_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcDerivedProfileDef_Operator" name="Operator" association="as_IfcDerivedProfileDef_Operator">
        <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcCartesianTransformationOperator2D"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcDerivedProfileDef_Operator_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcDerivedProfileDef_Operator_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcDerivedProfileDef_Label" name="Label">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcDerivedProfileDef_Label_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcDerivedProfileDef_Label_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcOpenCrossProfileDef" name="IfcOpenCrossProfileDef">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcOpenCrossProfileDef_CorrectProfileType" name="CorrectProfileType">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcOpenCrossProfileDef_CorrectProfileType" name="CorrectProfileType">
          <language>EXPRESS_WHERE</language>
          <body>SELF\IfcProfileDef.ProfileType = IfcProfileTypeEnum.CURVE</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcOpenCrossProfileDef_CorrespondingSlopeWidths" name="CorrespondingSlopeWidths">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcOpenCrossProfileDef_CorrespondingSlopeWidths" name="CorrespondingSlopeWidths">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(Slopes) = SIZEOF(Widths)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcOpenCrossProfileDef_CorrespondingTags" name="CorrespondingTags">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcOpenCrossProfileDef_CorrespondingTags" name="CorrespondingTags">
          <language>EXPRESS_WHERE</language>
          <body>(NOT EXISTS (Tags)) OR (SIZEOF(Tags) = (SIZEOF(Slopes) + 1))</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcOpenCrossProfileDef_gen_IfcProfileDef" general="cl_IfcProfileDef"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOpenCrossProfileDef_HorizontalWidths" name="HorizontalWidths">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcBoolean"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcOpenCrossProfileDef_HorizontalWidths_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcOpenCrossProfileDef_HorizontalWidths_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOpenCrossProfileDef_Widths" name="Widths_L[1:?]">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcNonNegativeLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcOpenCrossProfileDef_Widths_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcOpenCrossProfileDef_Widths_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOpenCrossProfileDef_Slopes" name="Slopes_L[1:?]">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPlaneAngleMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcOpenCrossProfileDef_Slopes_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcOpenCrossProfileDef_Slopes_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOpenCrossProfileDef_Tags" name="Tags_L[2:?]">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcOpenCrossProfileDef_Tags_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcOpenCrossProfileDef_Tags_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOpenCrossProfileDef_OffsetPoint" name="OffsetPoint" association="as_IfcOpenCrossProfileDef_OffsetPoint">
        <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcCartesianPoint"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcOpenCrossProfileDef_OffsetPoint_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcOpenCrossProfileDef_OffsetPoint_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcParameterizedProfileDef" name="IfcParameterizedProfileDef" isAbstract="true">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcParameterizedProfileDef_gen_IfcProfileDef" general="cl_IfcProfileDef"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcParameterizedProfileDef_Position" name="Position" association="as_IfcParameterizedProfileDef_Position">
        <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcAxis2Placement2D"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcParameterizedProfileDef_Position_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcParameterizedProfileDef_Position_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcArbitraryProfileDefWithVoids" name="IfcArbitraryProfileDefWithVoids">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcArbitraryProfileDefWithVoids_WR1" name="WR1">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcArbitraryProfileDefWithVoids_WR1" name="WR1">
          <language>EXPRESS_WHERE</language>
          <body>SELF\IfcProfileDef.ProfileType = AREA</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcArbitraryProfileDefWithVoids_WR2" name="WR2">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcArbitraryProfileDefWithVoids_WR2" name="WR2">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(temp &lt;* InnerCurves | temp.Dim &lt;&gt; 2)) = 0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcArbitraryProfileDefWithVoids_WR3" name="WR3">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcArbitraryProfileDefWithVoids_WR3" name="WR3">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(temp &lt;* InnerCurves | 'IFC4X3_ADD2.IFCLINE' IN TYPEOF(temp))) = 0</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcArbitraryProfileDefWithVoids_gen_IfcArbitraryClosedProfileDef" general="cl_IfcArbitraryClosedProfileDef"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcArbitraryProfileDefWithVoids_InnerCurves" name="InnerCurves_S[1:?]" association="as_IfcArbitraryProfileDefWithVoids_InnerCurves">
        <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcCurve"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcArbitraryProfileDefWithVoids_InnerCurves_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcArbitraryProfileDefWithVoids_InnerCurves_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcAsymmetricIShapeProfileDef" name="IfcAsymmetricIShapeProfileDef">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcAsymmetricIShapeProfileDef_ValidBottomFilletRadius" name="ValidBottomFilletRadius">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcAsymmetricIShapeProfileDef_ValidBottomFilletRadius" name="ValidBottomFilletRadius">
          <language>EXPRESS_WHERE</language>
          <body>(NOT(EXISTS(BottomFlangeFilletRadius))) OR 
(BottomFlangeFilletRadius &lt;= (BottomFlangeWidth - WebThickness)/2.)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcAsymmetricIShapeProfileDef_ValidFlangeThickness" name="ValidFlangeThickness">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcAsymmetricIShapeProfileDef_ValidFlangeThickness" name="ValidFlangeThickness">
          <language>EXPRESS_WHERE</language>
          <body>NOT(EXISTS(TopFlangeThickness)) OR ((BottomFlangeThickness + TopFlangeThickness) &lt; OverallDepth)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcAsymmetricIShapeProfileDef_ValidTopFilletRadius" name="ValidTopFilletRadius">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcAsymmetricIShapeProfileDef_ValidTopFilletRadius" name="ValidTopFilletRadius">
          <language>EXPRESS_WHERE</language>
          <body>(NOT(EXISTS(TopFlangeFilletRadius))) OR 
(TopFlangeFilletRadius &lt;= (TopFlangeWidth - WebThickness)/2.)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcAsymmetricIShapeProfileDef_ValidWebThickness" name="ValidWebThickness">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcAsymmetricIShapeProfileDef_ValidWebThickness" name="ValidWebThickness">
          <language>EXPRESS_WHERE</language>
          <body>(WebThickness &lt; BottomFlangeWidth) AND (WebThickness &lt; TopFlangeWidth)</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcAsymmetricIShapeProfileDef_gen_IfcParameterizedProfileDef" general="cl_IfcParameterizedProfileDef"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAsymmetricIShapeProfileDef_BottomFlangeWidth" name="BottomFlangeWidth">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcAsymmetricIShapeProfileDef_BottomFlangeWidth_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcAsymmetricIShapeProfileDef_BottomFlangeWidth_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAsymmetricIShapeProfileDef_OverallDepth" name="OverallDepth">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcAsymmetricIShapeProfileDef_OverallDepth_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcAsymmetricIShapeProfileDef_OverallDepth_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAsymmetricIShapeProfileDef_WebThickness" name="WebThickness">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcAsymmetricIShapeProfileDef_WebThickness_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcAsymmetricIShapeProfileDef_WebThickness_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAsymmetricIShapeProfileDef_BottomFlangeThickness" name="BottomFlangeThickness">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcAsymmetricIShapeProfileDef_BottomFlangeThickness_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcAsymmetricIShapeProfileDef_BottomFlangeThickness_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAsymmetricIShapeProfileDef_BottomFlangeFilletRadius" name="BottomFlangeFilletRadius">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcNonNegativeLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcAsymmetricIShapeProfileDef_BottomFlangeFilletRadius_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcAsymmetricIShapeProfileDef_BottomFlangeFilletRadius_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAsymmetricIShapeProfileDef_TopFlangeWidth" name="TopFlangeWidth">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcAsymmetricIShapeProfileDef_TopFlangeWidth_lower" value="1"/>
