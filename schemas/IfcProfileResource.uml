      </generalization>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcReinforcementBarProperties_TotalCrossSectionArea" name="TotalCrossSectionArea">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcAreaMeasure"/>
