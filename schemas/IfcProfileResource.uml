        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcIShapeProfileDef_FlangeEdgeRadius_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcIShapeProfileDef_FlangeEdgeRadius_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcIShapeProfileDef_FlangeSlope" name="FlangeSlope">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPlaneAngleMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcIShapeProfileDef_FlangeSlope_lower"/>
