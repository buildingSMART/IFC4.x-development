        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcReinforcementBarProperties_TotalCrossSectionArea_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcReinforcementBarProperties_SteelGrade" name="SteelGrade">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
