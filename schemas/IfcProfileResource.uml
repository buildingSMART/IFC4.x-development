      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRectangleHollowProfileDef_ValidInnerRadius" name="ValidInnerRadius">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcRectangleHollowProfileDef_ValidInnerRadius" name="ValidInnerRadius">
          <language>EXPRESS_WHERE</language>
          <body>NOT(EXISTS(InnerFilletRadius)) OR 
((InnerFilletRadius &lt;= (SELF\IfcRectangleProfileDef.XDim/2. - WallThickness)) AND 
 (InnerFilletRadius &lt;= (SELF\IfcRectangleProfileDef.YDim/2. - WallThickness)))</body>
