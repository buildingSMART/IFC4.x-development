      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcEllipseProfileDef_gen_IfcParameterizedProfileDef" general="cl_IfcParameterizedProfileDef"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcEllipseProfileDef_SemiAxis1" name="SemiAxis1">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
