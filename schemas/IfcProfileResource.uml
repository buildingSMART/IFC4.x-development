        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcEllipseProfileDef_SemiAxis1_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcEllipseProfileDef_SemiAxis2" name="SemiAxis2">
