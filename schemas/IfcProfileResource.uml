    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcLShapeProfileDef" name="IfcLShapeProfileDef">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcLShapeProfileDef_ValidThickness" name="ValidThickness">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcLShapeProfileDef_ValidThickness" name="ValidThickness">
          <language>EXPRESS_WHERE</language>
          <body>(Thickness &lt; Depth) AND (NOT(EXISTS(Width)) OR (Thickness &lt; Width))</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcLShapeProfileDef_gen_IfcParameterizedProfileDef" general="cl_IfcParameterizedProfileDef"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcLShapeProfileDef_Depth" name="Depth">
