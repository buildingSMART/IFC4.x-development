        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcEllipseProfileDef_SemiAxis2_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcEllipseProfileDef_SemiAxis2_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcIShapeProfileDef" name="IfcIShapeProfileDef">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcIShapeProfileDef_ValidFilletRadius" name="ValidFilletRadius">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcIShapeProfileDef_ValidFilletRadius" name="ValidFilletRadius">
          <language>EXPRESS_WHERE</language>
          <body>NOT(EXISTS(FilletRadius)) OR
((FilletRadius &lt;= (OverallWidth - WebThickness)/2.) AND 
 (FilletRadius &lt;= (OverallDepth - (2. * FlangeThickness))/2.))</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcIShapeProfileDef_ValidFlangeThickness" name="ValidFlangeThickness">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcIShapeProfileDef_ValidFlangeThickness" name="ValidFlangeThickness">
          <language>EXPRESS_WHERE</language>
          <body>(2. * FlangeThickness) &lt; OverallDepth</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcIShapeProfileDef_ValidWebThickness" name="ValidWebThickness">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcIShapeProfileDef_ValidWebThickness" name="ValidWebThickness">
          <language>EXPRESS_WHERE</language>
          <body>WebThickness &lt; OverallWidth</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcIShapeProfileDef_gen_IfcParameterizedProfileDef" general="cl_IfcParameterizedProfileDef"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcIShapeProfileDef_OverallWidth" name="OverallWidth">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcIShapeProfileDef_OverallWidth_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcIShapeProfileDef_OverallWidth_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcIShapeProfileDef_OverallDepth" name="OverallDepth">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcIShapeProfileDef_OverallDepth_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcIShapeProfileDef_OverallDepth_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcIShapeProfileDef_WebThickness" name="WebThickness">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcIShapeProfileDef_WebThickness_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcIShapeProfileDef_WebThickness_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcIShapeProfileDef_FlangeThickness" name="FlangeThickness">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcIShapeProfileDef_FlangeThickness_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcIShapeProfileDef_FlangeThickness_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcIShapeProfileDef_FilletRadius" name="FilletRadius">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcNonNegativeLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcIShapeProfileDef_FilletRadius_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcIShapeProfileDef_FilletRadius_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcIShapeProfileDef_FlangeEdgeRadius" name="FlangeEdgeRadius">
