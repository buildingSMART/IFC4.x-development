    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcDoorLiningProperties" name="IfcDoorLiningProperties">
      <ownedComment xmi:type="uml:Comment" xmi:id="cl_IfcDoorLiningProperties_comment_0">
        <body>DEPRECATED</body>
      </ownedComment>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcDoorLiningProperties_WR31" name="WR31">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcDoorLiningProperties_WR31" name="WR31">
          <language>EXPRESS_WHERE</language>
          <body>NOT(EXISTS(LiningDepth) AND NOT(EXISTS(LiningThickness)))</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcDoorLiningProperties_WR32" name="WR32">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcDoorLiningProperties_WR32" name="WR32">
          <language>EXPRESS_WHERE</language>
          <body>NOT(EXISTS(ThresholdDepth) AND NOT(EXISTS(ThresholdThickness)))</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcDoorLiningProperties_WR33" name="WR33">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcDoorLiningProperties_WR33" name="WR33">
          <language>EXPRESS_WHERE</language>
          <body>(EXISTS(TransomOffset) AND EXISTS(TransomThickness)) XOR
(NOT(EXISTS(TransomOffset)) AND NOT(EXISTS(TransomThickness)))</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcDoorLiningProperties_WR34" name="WR34">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcDoorLiningProperties_WR34" name="WR34">
          <language>EXPRESS_WHERE</language>
          <body>(EXISTS(CasingDepth) AND EXISTS(CasingThickness)) XOR
(NOT(EXISTS(CasingDepth)) AND NOT(EXISTS(CasingThickness)))</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcDoorLiningProperties_WR35" name="WR35">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcDoorLiningProperties_WR35" name="WR35">
          <language>EXPRESS_WHERE</language>
          <body>(EXISTS(SELF\IfcPropertySetDefinition.DefinesType[1])) 
AND 
('IFC4X3_ADD2.IFCDOORTYPE' IN TYPEOF(SELF\IfcPropertySetDefinition.DefinesType[1]))</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcDoorLiningProperties_gen_IfcPreDefinedPropertySet">
        <general xmi:type="uml:Class" href="IfcKernel.uml#cl_IfcPreDefinedPropertySet"/>
      </generalization>
