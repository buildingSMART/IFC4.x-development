        <specification xmi:type="uml:OpaqueExpression" xmi:id="dt_IfcDayInWeekNumber_ValidRange" name="ValidRange">
          <language>EXPRESS_WHERE</language>
          <body>{1 &lt;= SELF &lt;= 7}</body>
