    <packagedElement xmi:type="uml:DataType" xmi:id="dt_IfcDayInMonthNumber" name="IfcDayInMonthNumber">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcDayInMonthNumber_ValidRange" name="ValidRange">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="dt_IfcDayInMonthNumber_ValidRange" name="ValidRange">
          <language>EXPRESS_WHERE</language>
          <body>{1 &lt;= SELF &lt;= 31}</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="dt_IfcDayInMonthNumber_gen_integer">
        <general xmi:type="uml:DataType" href="ifc4x3_add2.uml#dt_integer"/>
