          <language>EXPRESS_WHERE</language>
          <body>SELF &gt; 0</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="dt_IfcCardinalPointReference_gen_integer">
        <general xmi:type="uml:DataType" href="ifc4x3_add2.uml#dt_integer"/>
