<?xml version="1.0" encoding="UTF-8"?>
<uml:Model xmlns:uml="http://www.eclipse.org/uml2/5.0.0/UML" xmlns:xmi="http://www.omg.org/spec/XMI/20131001" xmi:id="md_IfcMaterialResource" name="IfcMaterialResource" xmi:version="20131001">
  <packagedElement xmi:type="uml:Package" xmi:id="pk_IfcMaterialResource" name="IfcMaterialResource">
    <packagedElement xmi:type="uml:Constraint" xmi:id="ct_IfcMlsTotalThickness" name="IfcMlsTotalThickness">
      <specification xmi:type="uml:OpaqueExpression" xmi:id="ct_IfcMlsTotalThickness_expr" name="IfcMlsTotalThickness">
        <language>EXPRESS_FUNCTION</language>
        <body>FUNCTION IfcMlsTotalThickness
(LayerSet : IfcMaterialLayerSet) : IfcLengthMeasure;
  LOCAL
    Max : IfcLengthMeasure := LayerSet.MaterialLayers[1].LayerThickness;    
  END_LOCAL;

  IF SIZEOF(LayerSet.MaterialLayers) &gt; 1 THEN
    REPEAT i := 2 TO HIINDEX(LayerSet.MaterialLayers);
       Max := Max + LayerSet.MaterialLayers[i].LayerThickness;
    END_REPEAT;
  END_IF;
  RETURN (Max);

END_FUNCTION;
</body>
      </specification>
    </packagedElement>
    <packagedElement xmi:type="uml:DataType" xmi:id="dt_IfcCardinalPointReference" name="IfcCardinalPointReference">
