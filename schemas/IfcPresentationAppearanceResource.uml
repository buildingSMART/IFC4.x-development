<?xml version="1.0" encoding="UTF-8"?>
<uml:Model xmlns:uml="http://www.eclipse.org/uml2/5.0.0/UML" xmlns:xmi="http://www.omg.org/spec/XMI/20131001" xmi:id="md_IfcPresentationAppearanceResource" name="IfcPresentationAppearanceResource" xmi:version="20131001">
  <packagedElement xmi:type="uml:Package" xmi:id="pk_IfcPresentationAppearanceResource" name="IfcPresentationAppearanceResource">
    <packagedElement xmi:type="uml:Constraint" xmi:id="ct_IfcCorrectFillAreaStyle" name="IfcCorrectFillAreaStyle">
      <specification xmi:type="uml:OpaqueExpression" xmi:id="ct_IfcCorrectFillAreaStyle_expr" name="IfcCorrectFillAreaStyle">
        <language>EXPRESS_FUNCTION</language>
        <body>FUNCTION IfcCorrectFillAreaStyle
  (Styles : SET[1:?] OF IfcFillStyleSelect)
  :LOGICAL;

LOCAL
   Hatching : INTEGER := 0;
   Tiles    : INTEGER := 0;
   Colour   : INTEGER := 0;
   External : INTEGER := 0;
END_LOCAL;


External := SIZEOF(QUERY(Style &lt;* Styles |
  'IFC4X3_ADD2.IFCEXTERNALLYDEFINEDHATCHSTYLE' IN
   TYPEOF(Style)));

Hatching  := SIZEOF(QUERY(Style &lt;* Styles |
  'IFC4X3_ADD2.IFCFILLAREASTYLEHATCHING' IN
   TYPEOF(Style)));

Tiles     := SIZEOF(QUERY(Style &lt;* Styles |
  'IFC4X3_ADD2.IFCFILLAREASTYLETILES' IN
   TYPEOF(Style)));

Colour    := SIZEOF(QUERY(Style &lt;* Styles |
  'IFC4X3_ADD2.IFCCOLOUR' IN
   TYPEOF(Style)));


IF (External &gt; 1) THEN
  RETURN (FALSE);
END_IF;


IF ((External = 1) AND ((Hatching &gt; 0) OR (Tiles &gt; 0) OR (Colour &gt; 0))) THEN
  RETURN (FALSE);
END_IF;


IF (Colour &gt; 1) THEN
  RETURN (FALSE);
END_IF;

IF ((Hatching &gt; 0) AND (Tiles &gt;0)) THEN
  RETURN (FALSE);
END_IF;

RETURN(TRUE);

END_FUNCTION;
</body>
      </specification>
    </packagedElement>
    <packagedElement xmi:type="uml:DataType" xmi:id="dt_IfcFontStyle" name="IfcFontStyle">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcFontStyle_WR1" name="WR1">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="dt_IfcFontStyle_WR1" name="WR1">
          <language>EXPRESS_WHERE</language>
          <body>SELF IN ['normal','italic','oblique']</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="dt_IfcFontStyle_gen_string">
        <general xmi:type="uml:DataType" href="ifc4x3_add2.uml#dt_string"/>
