    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcCurveStyle" name="IfcCurveStyle">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCurveStyle_IdentifiableCurveStyle" name="IdentifiableCurveStyle">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcCurveStyle_IdentifiableCurveStyle" name="IdentifiableCurveStyle">
          <language>EXPRESS_WHERE</language>
          <body>EXISTS(CurveFont) OR EXISTS(CurveWidth) OR EXISTS(CurveColour)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCurveStyle_MeasureOfWidth" name="MeasureOfWidth">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcCurveStyle_MeasureOfWidth" name="MeasureOfWidth">
          <language>EXPRESS_WHERE</language>
          <body>(NOT(EXISTS(CurveWidth))) OR
('IFC4X3_ADD2.IFCPOSITIVELENGTHMEASURE' IN TYPEOF(CurveWidth)) OR 
 (('IFC4X3_ADD2.IFCDESCRIPTIVEMEASURE' IN TYPEOF(CurveWidth)) AND
 (CurveWidth = 'by layer'))</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcCurveStyle_gen_IfcPresentationStyle" general="cl_IfcPresentationStyle"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCurveStyle_CurveFont" name="CurveFont" type="un_IfcCurveFontOrScaledCurveFontSelect" association="as_IfcCurveStyle_CurveFont">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCurveStyle_CurveFont_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCurveStyle_CurveFont_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCurveStyle_CurveWidth" name="CurveWidth" type="un_IfcSizeSelect" association="as_IfcCurveStyle_CurveWidth">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCurveStyle_CurveWidth_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCurveStyle_CurveWidth_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCurveStyle_CurveColour" name="CurveColour" type="un_IfcColour" association="as_IfcCurveStyle_CurveColour">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCurveStyle_CurveColour_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCurveStyle_CurveColour_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCurveStyle_ModelOrDraughting" name="ModelOrDraughting">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcBoolean"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCurveStyle_ModelOrDraughting_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCurveStyle_ModelOrDraughting_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
