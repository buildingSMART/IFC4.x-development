      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcExternallyDefinedHatchStyle_gen_IfcExternalReference">
        <general xmi:type="uml:Class" href="IfcExternalReferenceResource.uml#cl_IfcExternalReference"/>
