    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcPixelTexture" name="IfcPixelTexture">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPixelTexture_MinPixelInS" name="MinPixelInS">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcPixelTexture_MinPixelInS" name="MinPixelInS">
          <language>EXPRESS_WHERE</language>
          <body>Width &gt;= 1</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPixelTexture_MinPixelInT" name="MinPixelInT">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcPixelTexture_MinPixelInT" name="MinPixelInT">
          <language>EXPRESS_WHERE</language>
          <body>Height &gt;= 1</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPixelTexture_NumberOfColours" name="NumberOfColours">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcPixelTexture_NumberOfColours" name="NumberOfColours">
          <language>EXPRESS_WHERE</language>
          <body>{1 &lt;= ColourComponents &lt;= 4}</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPixelTexture_PixelAsByteAndSameLength" name="PixelAsByteAndSameLength">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcPixelTexture_PixelAsByteAndSameLength" name="PixelAsByteAndSameLength">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(temp&lt;* Pixel |
 (BLENGTH(temp) MOD 8 = 0) AND
 (BLENGTH(temp) = BLENGTH(Pixel[1]))
)) = SIZEOF(Pixel)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPixelTexture_SizeOfPixelList" name="SizeOfPixelList">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcPixelTexture_SizeOfPixelList" name="SizeOfPixelList">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(Pixel) = (Width * Height)</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcPixelTexture_gen_IfcSurfaceTexture" general="cl_IfcSurfaceTexture"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPixelTexture_Width" name="Width">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcInteger"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcPixelTexture_Width_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPixelTexture_Width_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPixelTexture_Height" name="Height">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcInteger"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcPixelTexture_Height_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPixelTexture_Height_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPixelTexture_ColourComponents" name="ColourComponents">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcInteger"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcPixelTexture_ColourComponents_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPixelTexture_ColourComponents_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPixelTexture_Pixel" name="Pixel_L[1:?]">
