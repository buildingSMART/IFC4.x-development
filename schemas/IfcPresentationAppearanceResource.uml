        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCurveStyleFontAndScaling_CurveStyleFont_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCurveStyleFontAndScaling_CurveStyleFont_upper" value="1"/>
