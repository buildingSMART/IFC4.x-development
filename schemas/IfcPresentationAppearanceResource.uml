    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcBlobTexture" name="IfcBlobTexture">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcBlobTexture_RasterCodeByteStream" name="RasterCodeByteStream">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcBlobTexture_RasterCodeByteStream" name="RasterCodeByteStream">
          <language>EXPRESS_WHERE</language>
          <body>BLENGTH(RasterCode) MOD 8 = 0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcBlobTexture_SupportedRasterFormat" name="SupportedRasterFormat">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcBlobTexture_SupportedRasterFormat" name="SupportedRasterFormat">
          <language>EXPRESS_WHERE</language>
          <body>SELF.RasterFormat IN ['BMP', 'JPG', 'GIF', 'PNG']</body>
