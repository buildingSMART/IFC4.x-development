      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCurveStyleFontAndScaling_CurveFontScaling" name="CurveFontScaling">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveRatioMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCurveStyleFontAndScaling_CurveFontScaling_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCurveStyleFontAndScaling_CurveFontScaling_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcCurveStyleFontPattern" name="IfcCurveStyleFontPattern">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCurveStyleFontPattern_VisibleLengthGreaterEqualZero" name="VisibleLengthGreaterEqualZero">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcCurveStyleFontPattern_VisibleLengthGreaterEqualZero" name="VisibleLengthGreaterEqualZero">
          <language>EXPRESS_WHERE</language>
          <body>VisibleSegmentLength &gt;= 0.</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcCurveStyleFontPattern_gen_IfcPresentationItem">
        <general xmi:type="uml:Class" href="IfcPresentationDefinitionResource.uml#cl_IfcPresentationItem"/>
      </generalization>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCurveStyleFontPattern_VisibleSegmentLength" name="VisibleSegmentLength">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCurveStyleFontPattern_VisibleSegmentLength_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCurveStyleFontPattern_VisibleSegmentLength_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCurveStyleFontPattern_InvisibleSegmentLength" name="InvisibleSegmentLength">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcCurveStyleFontPattern_InvisibleSegmentLength_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcCurveStyleFontPattern_InvisibleSegmentLength_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
