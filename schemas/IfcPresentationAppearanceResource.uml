    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcDraughtingPreDefinedColour" name="IfcDraughtingPreDefinedColour">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcDraughtingPreDefinedColour_PreDefinedColourNames" name="PreDefinedColourNames">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcDraughtingPreDefinedColour_PreDefinedColourNames" name="PreDefinedColourNames">
          <language>EXPRESS_WHERE</language>
          <body>SELF\IfcPreDefinedItem.Name IN ['black','red','green','blue','yellow',
     'magenta','cyan','white','by layer']</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcDraughtingPreDefinedColour_gen_IfcPreDefinedColour" general="cl_IfcPreDefinedColour"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcDraughtingPreDefinedCurveFont" name="IfcDraughtingPreDefinedCurveFont">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcDraughtingPreDefinedCurveFont_PreDefinedCurveFontNames" name="PreDefinedCurveFontNames">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcDraughtingPreDefinedCurveFont_PreDefinedCurveFontNames" name="PreDefinedCurveFontNames">
          <language>EXPRESS_WHERE</language>
          <body>SELF\IfcPredefinedItem.Name IN
       ['continuous',
        'chain',
        'chain double dash',
        'dashed',
        'dotted',
        'by layer']</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcDraughtingPreDefinedCurveFont_gen_IfcPreDefinedCurveFont" general="cl_IfcPreDefinedCurveFont"/>
    </packagedElement>
