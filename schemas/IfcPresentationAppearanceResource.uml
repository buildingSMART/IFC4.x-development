        <general xmi:type="uml:Class" href="IfcExternalReferenceResource.uml#cl_IfcExternalReference"/>
      </generalization>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcExternallyDefinedTextFont" name="IfcExternallyDefinedTextFont">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcExternallyDefinedTextFont_gen_IfcExternalReference">
        <general xmi:type="uml:Class" href="IfcExternalReferenceResource.uml#cl_IfcExternalReference"/>
      </generalization>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcFillAreaStyle" name="IfcFillAreaStyle">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcFillAreaStyle_ConsistentHatchStyleDef" name="ConsistentHatchStyleDef">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcFillAreaStyle_ConsistentHatchStyleDef" name="ConsistentHatchStyleDef">
          <language>EXPRESS_WHERE</language>
          <body>IfcCorrectFillAreaStyle(SELF.FillStyles)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcFillAreaStyle_MaxOneColour" name="MaxOneColour">
