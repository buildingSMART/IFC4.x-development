    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcFillAreaStyleHatching" name="IfcFillAreaStyleHatching">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcFillAreaStyleHatching_PatternStart2D" name="PatternStart2D">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcFillAreaStyleHatching_PatternStart2D" name="PatternStart2D">
