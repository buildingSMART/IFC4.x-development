        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcEventType_UserDefinedEventTriggerType_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcEventType_UserDefinedEventTriggerType_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcProcedure" name="IfcProcedure">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcProcedure_HasName" name="HasName">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcProcedure_HasName" name="HasName">
