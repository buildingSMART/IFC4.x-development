        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcEvent_PredefinedType_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcEvent_EventTriggerType" name="EventTriggerType" type="en_IfcEventTriggerTypeEnum">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcEvent_EventTriggerType_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcEvent_EventTriggerType_upper" value="1"/>
