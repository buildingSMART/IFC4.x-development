      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcEvent_UserDefinedEventTriggerType" name="UserDefinedEventTriggerType">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
