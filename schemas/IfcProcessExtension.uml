      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcTaskTypeEnum_REMOVAL" name="REMOVAL"/>
      <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="en_IfcTaskTypeEnum_RENOVATION" name="RENOVATION"/>
