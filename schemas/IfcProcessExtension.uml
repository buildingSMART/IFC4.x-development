      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcEventType_gen_IfcTypeProcess">
        <general xmi:type="uml:Class" href="IfcKernel.uml#cl_IfcTypeProcess"/>
      </generalization>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcEventType_PredefinedType" name="PredefinedType" type="en_IfcEventTypeEnum">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcEventType_PredefinedType_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcEventType_PredefinedType_upper" value="1"/>
