        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcEvent_EventOccurenceTime_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcEventType" name="IfcEventType">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcEventType_CorrectEventTriggerType" name="CorrectEventTriggerType">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcEventType_CorrectEventTriggerType" name="CorrectEventTriggerType">
