        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcStructuralLoadGroup_ActionSource_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcStructuralLoadGroup_ActionSource_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcStructuralLoadGroup_Coefficient" name="Coefficient">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcRatioMeasure"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcStructuralLoadGroup_Coefficient_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcStructuralLoadGroup_Coefficient_upper" value="1"/>
