        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcStructuralLoadGroup_PredefinedType_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcStructuralLoadGroup_ActionType" name="ActionType" type="en_IfcActionTypeEnum">
