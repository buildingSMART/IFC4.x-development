          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(['IFC4X3_ADD2.IFCSTRUCTURALLOADPLANARFORCE', 'IFC4X3_ADD2.IFCSTRUCTURALLOADTEMPERATURE'] * TYPEOF(SELF\IfcStructuralActivity.AppliedLoad)) = 1</body>
