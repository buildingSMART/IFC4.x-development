    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcStructuralCurveAction" name="IfcStructuralCurveAction">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcStructuralCurveAction_HasObjectType" name="HasObjectType">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcStructuralCurveAction_HasObjectType" name="HasObjectType">
          <language>EXPRESS_WHERE</language>
          <body>(PredefinedType &lt;&gt; IfcStructuralCurveActivityTypeEnum.USERDEFINED) OR EXISTS(SELF\IfcObject.ObjectType)</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcStructuralCurveAction_ProjectedIsGlobal" name="ProjectedIsGlobal">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcStructuralCurveAction_ProjectedIsGlobal" name="ProjectedIsGlobal">
          <language>EXPRESS_WHERE</language>
          <body>(NOT EXISTS(ProjectedOrTrue)) OR
((ProjectedOrTrue &lt;&gt; PROJECTED_LENGTH) OR
 (SELF\IfcStructuralActivity.GlobalOrLocal = GLOBAL_COORDS))</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcStructuralCurveAction_SuitablePredefinedType" name="SuitablePredefinedType">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcStructuralCurveAction_SuitablePredefinedType" name="SuitablePredefinedType">
          <language>EXPRESS_WHERE</language>
          <body>PredefinedType &lt;&gt; IfcStructuralCurveActivityTypeEnum.EQUIDISTANT</body>
