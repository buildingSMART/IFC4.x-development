    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcStructuralLoadGroup" name="IfcStructuralLoadGroup">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcStructuralLoadGroup_HasObjectType" name="HasObjectType">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcStructuralLoadGroup_HasObjectType" name="HasObjectType">
          <language>EXPRESS_WHERE</language>
          <body>(
  (PredefinedType &lt;&gt; IfcLoadGroupTypeEnum.USERDEFINED) AND
  (ActionType &lt;&gt; IfcActionTypeEnum.USERDEFINED) AND
  (ActionSource &lt;&gt; IfcActionSourceTypeEnum.USERDEFINED)
) OR EXISTS(SELF\IfcObject.ObjectType)</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcStructuralLoadGroup_gen_IfcGroup">
        <general xmi:type="uml:Class" href="IfcKernel.uml#cl_IfcGroup"/>
      </generalization>
