    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcStructuralResultGroup" name="IfcStructuralResultGroup">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcStructuralResultGroup_HasObjectType" name="HasObjectType">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcStructuralResultGroup_HasObjectType" name="HasObjectType">
          <language>EXPRESS_WHERE</language>
          <body>(TheoryType &lt;&gt; IfcAnalysisTheoryTypeEnum.USERDEFINED) OR EXISTS(SELF\IfcObject.ObjectType)</body>
        </specification>
      </ownedRule>
