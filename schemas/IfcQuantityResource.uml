<?xml version="1.0" encoding="UTF-8"?>
<uml:Model xmlns:uml="http://www.eclipse.org/uml2/5.0.0/UML" xmlns:xmi="http://www.omg.org/spec/XMI/20131001" xmi:id="md_IfcQuantityResource" name="IfcQuantityResource" xmi:version="20131001">
  <packagedElement xmi:type="uml:Package" xmi:id="pk_IfcQuantityResource" name="IfcQuantityResource">
    <packagedElement xmi:type="uml:Constraint" xmi:id="ct_IfcUniqueQuantityNames" name="IfcUniqueQuantityNames">
      <specification xmi:type="uml:OpaqueExpression" xmi:id="ct_IfcUniqueQuantityNames_expr" name="IfcUniqueQuantityNames">
        <language>EXPRESS_FUNCTION</language>
        <body>FUNCTION IfcUniqueQuantityNames
(Properties : SET [1:?] OF IfcPhysicalQuantity)
:LOGICAL;

LOCAL
  Names : SET OF IfcLabel := [];
END_LOCAL;

REPEAT i:=1 TO HIINDEX(Properties);
  Names := Names + Properties[i].Name;
END_REPEAT;
RETURN (SIZEOF(Names) = SIZEOF(Properties));

END_FUNCTION;
</body>
      </specification>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcPhysicalQuantity" name="IfcPhysicalQuantity" isAbstract="true">
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPhysicalQuantity_Name" name="Name">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcPhysicalQuantity_Name_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPhysicalQuantity_Name_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPhysicalQuantity_Description" name="Description">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcText"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcPhysicalQuantity_Description_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPhysicalQuantity_Description_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcPhysicalComplexQuantity" name="IfcPhysicalComplexQuantity">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPhysicalComplexQuantity_NoSelfReference" name="NoSelfReference">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcPhysicalComplexQuantity_NoSelfReference" name="NoSelfReference">
          <language>EXPRESS_WHERE</language>
          <body>SIZEOF(QUERY(temp &lt;* HasQuantities | SELF :=: temp)) = 0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPhysicalComplexQuantity_UniqueQuantityNames" name="UniqueQuantityNames">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcPhysicalComplexQuantity_UniqueQuantityNames" name="UniqueQuantityNames">
          <language>EXPRESS_WHERE</language>
          <body>IfcUniqueQuantityNames(HasQuantities)</body>
        </specification>
      </ownedRule>
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcPhysicalComplexQuantity_gen_IfcPhysicalQuantity" general="cl_IfcPhysicalQuantity"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPhysicalComplexQuantity_HasQuantities" name="HasQuantities_S[1:?]" type="cl_IfcPhysicalQuantity" association="as_IfcPhysicalComplexQuantity_HasQuantities">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcPhysicalComplexQuantity_HasQuantities_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPhysicalComplexQuantity_HasQuantities_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPhysicalComplexQuantity_Discrimination" name="Discrimination">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcPhysicalComplexQuantity_Discrimination_lower" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPhysicalComplexQuantity_Discrimination_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPhysicalComplexQuantity_Quality" name="Quality">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcPhysicalComplexQuantity_Quality_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPhysicalComplexQuantity_Quality_upper" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPhysicalComplexQuantity_Usage" name="Usage">
        <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="at_IfcPhysicalComplexQuantity_Usage_lower"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="at_IfcPhysicalComplexQuantity_Usage_upper" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcPhysicalSimpleQuantity" name="IfcPhysicalSimpleQuantity" isAbstract="true">
      <generalization xmi:type="uml:Generalization" xmi:id="cl_IfcPhysicalSimpleQuantity_gen_IfcPhysicalQuantity" general="cl_IfcPhysicalQuantity"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPhysicalSimpleQuantity_Unit" name="Unit" association="as_IfcPhysicalSimpleQuantity_Unit">
        <type xmi:type="uml:Class" href="IfcMeasureResource.uml#cl_IfcNamedUnit"/>
