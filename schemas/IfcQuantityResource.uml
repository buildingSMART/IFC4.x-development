    <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcQuantityArea" name="IfcQuantityArea">
      <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcQuantityArea_WR21" name="WR21">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="cl_IfcQuantityArea_WR21" name="WR21">
          <language>EXPRESS_WHERE</language>
          <body>NOT(EXISTS(SELF\IfcPhysicalSimpleQuantity.Unit)) OR
   (SELF\IfcPhysicalSimpleQuantity.Unit.UnitType = IfcUnitEnum.AREAUNIT)</body>
        </specification>
